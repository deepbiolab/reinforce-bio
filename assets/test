def extend_clone_embedding(net, mean_init=True):
    """Add one new clone to the embedding table.

    Args:
        net: KineticsNet model (modified in-place).
        mean_init: if True, init new row as mean of existing embeddings.

    Returns:
        net: modified model.
        new_idx: integer index of the new clone.
    """
    old_emb = net.clone_emb
    n_old = old_emb.num_embeddings
    emb_dim = old_emb.embedding_dim

    new_emb = nn.Embedding(n_old + 1, emb_dim)
    with torch.no_grad():
        new_emb.weight[:n_old] = old_emb.weight.data.clone()
        if mean_init:
            new_emb.weight[n_old] = old_emb.weight.data.mean(dim=0)
        # else: random init from nn.Embedding default

    device = next(net.parameters()).device
    net.clone_emb = new_emb.to(device)
    return net, n_old  # new_idx = n_old (0-indexed)


def freeze_for_mode(net, mode, new_idx):
    """Freeze/unfreeze parameters for few-shot adaptation.

    Args:
        net: KineticsNet with extended embedding.
        mode: "embedding_only" or "head_tuning".
        new_idx: index of the new clone embedding row.

    Returns:
        trainable_params: list of parameters that require grad.
    """
    # Freeze everything first
    for p in net.parameters():
        p.requires_grad = False

    def _last_row_hook(grad):
        mask = torch.zeros_like(grad)
        mask[new_idx] = 1.0
        return grad * mask

    if mode == "embedding_only":
        # Unfreeze embedding weights, mask gradient to only update last row
        net.clone_emb.weight.requires_grad = True
        net.clone_emb.weight.register_hook(_last_row_hook)
        return [net.clone_emb.weight]

    elif mode == "head_tuning":
        # Unfreeze embedding (last row only via hook) + last Linear layer
        net.clone_emb.weight.requires_grad = True
        net.clone_emb.weight.register_hook(_last_row_hook)

        # Last layer of the Sequential network (Linear, Tanh, ..., Linear)
        last_layer = net.net[-1]
        for p in last_layer.parameters():
            p.requires_grad = True

        return [net.clone_emb.weight] + list(last_layer.parameters())

    elif mode == "full_head_tuning":
        # Unfreeze ENTIRE embedding layer + last Linear layer. No gradient hook!
        net.clone_emb.weight.requires_grad = True

        # Last layer of the Sequential network
        last_layer = net.net[-1]
        for p in last_layer.parameters():
            p.requires_grad = True

        return [net.clone_emb.weight] + list(last_layer.parameters())

    else:
        raise ValueError(f"Unknown mode: {mode}")


def finetune_model(net, data, shot_ids, val_ids, stats, new_idx, mode, cfg, device):
    """Fine-tune a single model for a new clone.

    All shot data must already have clone_idx set to new_idx.

    Args:
        net: KineticsNet with extended embedding.
        data: dict of ExperimentData for shot + val runs.
        shot_ids: list of exp_ids for training.
        val_ids: list of exp_ids for validation.
        stats: normalization stats dict.
        new_idx: index of the new clone in the embedding table.
        mode: "embedding_only" or "head_tuning".
        cfg: config dict.
        device: torch device.

    Returns:
        net: fine-tuned model with best checkpoint restored.
    """
    net = net.to(device)
    trainable = freeze_for_mode(net, mode, new_idx)
    optimizer = torch.optim.Adam(trainable, lr=cfg["finetune_lr"])
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
            optimizer,
            mode='min',
            factor=0.5,
            patience=5,
            min_lr=1e-5
        )
    best_val = float("inf")
    best_state = None
    patience_counter = 0
    state_std = stats["state_std"].to(device)

    for epoch in range(cfg["finetune_epochs"]):
        net.train()
        batch = make_batch(shot_ids, data, device)
        # Override clone indices to new_idx
        batch = batch._replace(
            clone_indices=torch.full_like(batch.clone_indices, new_idx),
        )

        optimizer.zero_grad()
        train_loss = None
        try:
            preds, t_eval = solve_batch(net, batch, stats, cfg)
            if torch.isnan(preds).any():
                continue
            interp = interp_to_targets(preds, t_eval, batch.times, batch.pad_masks)
            train_loss = masked_nrmse(
                interp, batch.states, batch.obs_masks, state_std,
            ).mean()
            if torch.isnan(train_loss):
                continue
            train_loss.backward()
            torch.nn.utils.clip_grad_norm_(trainable, cfg["grad_clip"])
            optimizer.step()
        except Exception as e:
            logger.debug("Finetune batch skipped: %s", e)
            continue

        # Validation
        if val_ids:
            net.eval()
            with torch.no_grad():
                val_batch = make_batch(val_ids, data, device)
                val_batch = val_batch._replace(
                    clone_indices=torch.full_like(
                        val_batch.clone_indices, new_idx,
                    ),
                )
                vp, vt = solve_batch(net, val_batch, stats, cfg)
                vi = interp_to_targets(
                    vp, vt, val_batch.times, val_batch.pad_masks,
                )
                val_nrmse = masked_nrmse(
                    vi, val_batch.states, val_batch.obs_masks, state_std,
                ).mean().item()
        else:
            val_nrmse = train_loss.item()  # use train loss as proxy

        scheduler.step(val_nrmse)

        if val_nrmse < best_val:
            best_val = val_nrmse
            best_state = copy.deepcopy(net.state_dict())
            patience_counter = 0
        else:
            patience_counter += 1

        if patience_counter >= cfg["finetune_patience"]:
            break

    if best_state is not None:
        net.load_state_dict(best_state)
    return net


def retrain_with_shots(data, base_train_ids, base_val_ids, shot_ids,
                       stats, n_clones, cfg, device):
    """Retrain ensemble from scratch with base data + shot holdout runs.

    The holdout clone IS in the vocabulary (n_clones already includes it).
    """
    combined_train = base_train_ids + shot_ids
    models, _ = train_ensemble(
        data, combined_train, base_val_ids, stats, n_clones, cfg, device,
    )
    return models


def run_transfer_experiment(models, base_data, holdout_data, holdout_clone,
                            base_train_ids, base_val_ids, stats, vocab,
                            cfg, device):
    """Run transfer learning experiment: 3 methods x 3 shots.

    Methods: retrain, embedding_only, head_tuning.
    Shots: 0, 2, 4.

    Args:
        models: pre-trained ensemble (list of KineticsNet).
        base_data: dict of ExperimentData for base clones.
        holdout_data: dict of ExperimentData for holdout clone.
        holdout_clone: name of the holdout clone.
        base_train_ids: list of base training exp_ids.
        base_val_ids: list of base validation exp_ids.
        stats: normalization stats dict.
        vocab: vocabulary dict with n_clones, clone_names.
        cfg: config dict.
        device: torch device.

    Returns:
        results: {method: {n_shot: {"nrmse": float, "r2": float}}}.
    """
    holdout_ids = list(holdout_data.keys())
    n_holdout = len(holdout_ids)

    # Deterministic shuffle for reproducible shot selection
    rng = np.random.RandomState(cfg["seed"])
    shuffled = holdout_ids.copy()
    rng.shuffle(shuffled)

    results = {}
    n_clones = vocab["n_clones"]  # base clones count (holdout excluded)

    # ===== 0-shot (shared across all methods) =====
    logger.info("=== 0-shot evaluation (shared) ===")

    # Extend each model's embedding with mean init
    zero_shot_models = []
    new_idx = None
    for net in models:
        net_copy = copy.deepcopy(net)
        net_copy, new_idx = extend_clone_embedding(net_copy, mean_init=True)
        zero_shot_models.append(net_copy)

    # Override holdout data clone_indices to new_idx
    holdout_data_adapted = {}
    for eid, exp in holdout_data.items():
        holdout_data_adapted[eid] = exp._replace(clone_idx=new_idx)

    all_data_adapted = {**base_data, **holdout_data_adapted}

    # Evaluate 0-shot on ALL holdout runs
    zero_metrics = evaluate_ensemble(
        zero_shot_models, all_data_adapted, holdout_ids, stats, cfg, device,
    )
    zero_shot_result = {
        "nrmse": zero_metrics["avg_nrmse"],
        "r2": zero_metrics["avg_r2"],
    }

    for method in ["retrain", "embedding_only", "head_tuning", "full_head_tuning"]:
        results[method] = {0: zero_shot_result}  # shared 0-shot

    logger.info(
        "0-shot — NRMSE: %.4f, R²: %.4f",
        zero_shot_result["nrmse"], zero_shot_result["r2"],
    )

    # ===== 2-shot and 4-shot =====
    for n_shot in [2, 4]:
        if n_shot > n_holdout:
            logger.warning(
                "Not enough holdout runs (%d) for %d-shot", n_holdout, n_shot,
            )
            continue

        shot_ids = shuffled[:n_shot]
        eval_ids = shuffled[n_shot:]  # remaining holdout runs for evaluation

        if not eval_ids:
            logger.warning("No evaluation runs left for %d-shot", n_shot)
            continue

        logger.info(
            "=== %d-shot: %d train, %d eval ===",
            n_shot, n_shot, len(eval_ids),
        )

        # Few-shot: use all shots for training, no val split (too few runs)
        ft_train_ids = shot_ids
        ft_val_ids = []

        # --- Method 1: Retrain ---
        logger.info("  Retrain from scratch...")
        # Holdout clone gets index n_clones in extended vocabulary
        retrain_data = {**base_data}
        for eid in shot_ids:
            retrain_data[eid] = holdout_data[eid]._replace(clone_idx=n_clones)

        retrain_models = retrain_with_shots(
            retrain_data, base_train_ids, base_val_ids, shot_ids,
            stats, n_clones + 1, cfg, device,
        )

        # Evaluate retrain on remaining holdout
        eval_data_retrain = {}
        for eid in eval_ids:
            eval_data_retrain[eid] = holdout_data[eid]._replace(
                clone_idx=n_clones,
            )
        retrain_data_full = {**base_data, **eval_data_retrain}

        r_metrics = evaluate_ensemble(
            retrain_models, retrain_data_full, eval_ids, stats, cfg, device,
        )
        results["retrain"][n_shot] = {
            "nrmse": r_metrics["avg_nrmse"],
            "r2": r_metrics["avg_r2"],
        }
        logger.info(
            "  Retrain %d-shot — NRMSE: %.4f, R²: %.4f",
            n_shot, r_metrics["avg_nrmse"], r_metrics["avg_r2"],
        )

        # --- Method 2: Embedding-only ---
        logger.info("  Embedding-only finetune...")
        emb_models = []
        for net in models:
            net_copy = copy.deepcopy(net)
            net_copy, ni = extend_clone_embedding(net_copy, mean_init=True)
            adapted_shot = {}
            for eid in shot_ids:
                adapted_shot[eid] = holdout_data[eid]._replace(clone_idx=ni)
            ft_train_adapted = list(adapted_shot.keys())[:len(ft_train_ids)]
            ft_val_adapted = list(adapted_shot.keys())[len(ft_train_ids):]
            net_copy = finetune_model(
                net_copy, adapted_shot, ft_train_adapted, ft_val_adapted,
                stats, ni, "embedding_only", cfg, device,
            )
            emb_models.append(net_copy)

        eval_data_emb = {}
        for eid in eval_ids:
            eval_data_emb[eid] = holdout_data[eid]._replace(clone_idx=n_clones)
        emb_data_full = {**base_data, **eval_data_emb}

        e_metrics = evaluate_ensemble(
            emb_models, emb_data_full, eval_ids, stats, cfg, device,
        )
        results["embedding_only"][n_shot] = {
            "nrmse": e_metrics["avg_nrmse"],
            "r2": e_metrics["avg_r2"],
        }
        logger.info(
            "  Embedding %d-shot — NRMSE: %.4f, R²: %.4f",
            n_shot, e_metrics["avg_nrmse"], e_metrics["avg_r2"],
        )

        # --- Method 3: Head-tuning ---
        logger.info("  Head-tuning finetune...")
        ht_models = []
        for net in models:
            net_copy = copy.deepcopy(net)
            net_copy, ni = extend_clone_embedding(net_copy, mean_init=True)
            adapted_shot = {}
            for eid in shot_ids:
                adapted_shot[eid] = holdout_data[eid]._replace(clone_idx=ni)
            ft_train_adapted = list(adapted_shot.keys())[:len(ft_train_ids)]
            ft_val_adapted = list(adapted_shot.keys())[len(ft_train_ids):]
            net_copy = finetune_model(
                net_copy, adapted_shot, ft_train_adapted, ft_val_adapted,
                stats, ni, "head_tuning", cfg, device,
            )
            ht_models.append(net_copy)

        eval_data_ht = {}
        for eid in eval_ids:
            eval_data_ht[eid] = holdout_data[eid]._replace(clone_idx=n_clones)
        ht_data_full = {**base_data, **eval_data_ht}

        h_metrics = evaluate_ensemble(
            ht_models, ht_data_full, eval_ids, stats, cfg, device,
        )
        results["head_tuning"][n_shot] = {
            "nrmse": h_metrics["avg_nrmse"],
            "r2": h_metrics["avg_r2"],
        }
        logger.info(
            "  Head-tune %d-shot — NRMSE: %.4f, R²: %.4f",
            n_shot, h_metrics["avg_nrmse"], h_metrics["avg_r2"],
        )

        # --- Method 4: Full Head-tuning ---
        logger.info("  Full Head-tuning finetune...")
        fht_models = []
        for net in models:
            net_copy = copy.deepcopy(net)
            net_copy, ni = extend_clone_embedding(net_copy, mean_init=True)
            adapted_shot = {}
            for eid in shot_ids:
                adapted_shot[eid] = holdout_data[eid]._replace(clone_idx=ni)
            ft_train_adapted = list(adapted_shot.keys())[:len(ft_train_ids)]
            ft_val_adapted = list(adapted_shot.keys())[len(ft_train_ids):]
            net_copy = finetune_model(
                net_copy, adapted_shot, ft_train_adapted, ft_val_adapted,
                stats, ni, "full_head_tuning", cfg, device,
            )
            fht_models.append(net_copy)

        eval_data_fht = {}
        for eid in eval_ids:
            eval_data_fht[eid] = holdout_data[eid]._replace(clone_idx=n_clones)
        fht_data_full = {**base_data, **eval_data_fht}

        fh_metrics = evaluate_ensemble(
            fht_models, fht_data_full, eval_ids, stats, cfg, device,
        )
        results["full_head_tuning"][n_shot] = {
            "nrmse": fh_metrics["avg_nrmse"],
            "r2": fh_metrics["avg_r2"],
        }
        logger.info(
            "  Full Head-tune %d-shot — NRMSE: %.4f, R²: %.4f",
            n_shot, fh_metrics["avg_nrmse"], fh_metrics["avg_r2"],
        )

    # Store 4-shot adapted models for embedding visualization
    if 4 in results.get("retrain", {}):
        results["models"] = {
            "retrain": retrain_models,
            "embedding_only": emb_models,
            "head_tuning": ht_models,
            "full_head_tuning": fht_models,
        }

    return results


