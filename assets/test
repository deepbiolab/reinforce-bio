def main(args):
    """
    Full nano_biopfm pipeline: data → train → evaluate → transfer → visualize.

    Phases:
        1. Data loading and splitting
        2. Base ensemble training
        3. Base model evaluation (train vs test)
        4. Free-run vs stepwise comparison
        5. Clone embedding visualization
        6. Transfer learning (3 methods × 3 shots)
        7. Prediction examples
    """
    device = get_device(args.device)
    out_dir = args.output
    os.makedirs(out_dir, exist_ok=True)
    logger.info("Device: %s | Output: %s", device, out_dir)

    # ========== Phase 1: Data ==========
    logger.info("=" * 60)
    logger.info("Phase 1: Loading data")
    data, vocab = load_and_preprocess(args.data, CFG)
    logger.info("Loaded %d experiments, %d clones: %s",
                len(data), vocab["n_clones"], vocab["clone_names"])

    base_data, holdout_data = split_holdout(data, args.holdout_clone, CFG)
    train_ids, val_ids = split_train_val(base_data, CFG["val_ratio"], CFG["seed"])
    stats = compute_stats(base_data, train_ids, CFG)

    # Two-way split only: val_ids used for both early stopping and evaluation
    eval_ids = val_ids
    logger.info("Splits — train: %d, val/eval: %d, holdout: %d",
                len(train_ids), len(eval_ids), len(holdout_data))

    # ========== Phase 2: Train Base Ensemble ==========
    logger.info("=" * 60)
    logger.info("Phase 2: Training base ensemble (%d models)", CFG["n_ensemble"])
    models, histories = train_ensemble(
        base_data, train_ids, val_ids, stats, vocab["n_clones"], CFG, device,
    )
    plot_training_metrics(histories, os.path.join(out_dir, "training_metrics.png"), CFG)

    # ========== Phase 3: Evaluate Base Model ==========
    logger.info("=" * 60)
    logger.info("Phase 3: Evaluating base model")
    train_metrics = evaluate_ensemble(models, base_data, train_ids, stats, CFG, device)
    eval_metrics = evaluate_ensemble(models, base_data, eval_ids, stats, CFG, device)
    logger.info("Train — NRMSE: %.4f  R²: %.4f", train_metrics["avg_nrmse"], train_metrics["avg_r2"])
    logger.info("Val   — NRMSE: %.4f  R²: %.4f", eval_metrics["avg_nrmse"], eval_metrics["avg_r2"])
    plot_metrics_comparison(
        train_metrics, eval_metrics, CFG["state_cols"],
        os.path.join(out_dir, "metrics_comparison.png"), CFG,
    )

    # ========== Phase 4: Free-run vs Stepwise ==========
    logger.info("=" * 60)
    logger.info("Phase 4: Free-run vs Stepwise comparison")
    sw_metrics = evaluate_stepwise(models, base_data, eval_ids, stats, CFG, device)
    logger.info("Stepwise — NRMSE: %.4f  R²: %.4f  Resets: %.1f",
                sw_metrics["avg_nrmse"], sw_metrics["avg_r2"], sw_metrics.get("avg_n_resets", 0))
    plot_freerun_vs_stepwise(
        eval_metrics, sw_metrics, CFG["state_cols"],
        os.path.join(out_dir, "freerun_vs_stepwise.png"), CFG,
    )

    # ========== Phase 4.5: Stepwise vs Free-run Trajectories ==========
    logger.info("=" * 60)
    logger.info("Phase 4.5: Stepwise vs Free-run trajectory overlay")
    plot_stepwise_vs_freerun_trajectories(
        models, base_data, eval_ids, stats, CFG, device,
        os.path.join(out_dir, "stepwise_trajectories.png"),
    )

    # ========== Phase 5: Embedding Visualization ==========
    logger.info("=" * 60)
    logger.info("Phase 5: Embedding visualization")
    # Only visualize base clones (exclude holdout which isn't in vocabulary)
    base_clone_names = [c for c in vocab["clone_names"] if c != args.holdout_clone]
    plot_embeddings(models, base_clone_names, os.path.join(out_dir, "embeddings.png"), CFG)

    # ========== Phase 6: Transfer Learning ==========
    logger.info("=" * 60)
    logger.info("Phase 6: Transfer learning experiment")
    transfer_results = run_transfer_experiment(
        models, base_data, holdout_data, args.holdout_clone,
        train_ids, val_ids, stats, vocab, CFG, device,
    )
    plot_transfer_bars(transfer_results, os.path.join(out_dir, "transfer_learning.png"), CFG)

    # ========== Phase 6.5: Transfer Embedding Visualization ==========
    logger.info("=" * 60)
    logger.info("Phase 6.5: Transfer embedding comparison")
    plot_transfer_embeddings(
        transfer_results, base_clone_names,
        os.path.join(out_dir, "transfer_embeddings.png"), CFG,
    )

    # ========== Phase 7: Prediction Examples ==========
    logger.info("=" * 60)
    logger.info("Phase 7: Prediction examples")
    plot_predictions(
        models, base_data, eval_ids[:3], stats, CFG, device,
        os.path.join(out_dir, "prediction_examples.png"),
    )

    # ========== Summary ==========
    logger.info("=" * 60)
    logger.info("All results saved to: %s", out_dir)
    logger.info("  training_metrics.png       — loss and NRMSE curves")
    logger.info("  metrics_comparison.png     — train vs val metrics (4 metrics)")
    logger.info("  freerun_vs_stepwise.png    — free-run vs stepwise comparison")
    logger.info("  stepwise_trajectories.png  — stepwise vs free-run overlay")
    logger.info("  embeddings.png             — clone embedding PCA")
    logger.info("  transfer_learning.png      — few-shot adaptation (3×3)")
    logger.info("  transfer_embeddings.png    — transfer embedding comparison")
    logger.info("  prediction_examples.png    — example trajectories")
    logger.info("Done!")


