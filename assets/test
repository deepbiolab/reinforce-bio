def _setup_style():
    """Apply a clean publication-ready matplotlib style."""
    plt.rcParams.update({
        "figure.facecolor": "white",
        "axes.facecolor": "white",
        "axes.grid": True,
        "grid.alpha": 0.3,
        "axes.spines.top": False,
        "axes.spines.right": False,
        "font.size": 10,
    })


def plot_training_metrics(histories, save_path, cfg):
    """
    Plot ensemble training loss and validation NRMSE curves.

    Args:
        histories: list of dicts, one per ensemble member,
                   each with keys "train_loss" and "val_nrmse".
        save_path: output PNG path.
        cfg: configuration dict.
    """
    _setup_style()
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=cfg["figsize_single"])
    cmap = plt.get_cmap("tab10")

    for i, h in enumerate(histories):
        color = cmap(i)
        ax1.plot(h["train_loss"], label=f"Model {i}", color=color, alpha=0.8)
        ax2.plot(h["val_nrmse"], label=f"Model {i}", color=color, alpha=0.8)

    ax1.set_xlabel("Epoch")
    ax1.set_ylabel("Training Loss (NRMSE)")
    ax1.set_title("Training Loss")
    ax1.legend(fontsize=8)

    ax2.set_xlabel("Epoch")
    ax2.set_ylabel("Validation NRMSE")
    ax2.set_title("Validation NRMSE")
    ax2.legend(fontsize=8)

    fig.suptitle("Ensemble Training Metrics", fontsize=13, fontweight="bold")
    fig.tight_layout()
    os.makedirs(os.path.dirname(save_path) or ".", exist_ok=True)
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


def plot_metrics_comparison(train_metrics, val_metrics, state_cols, save_path, cfg):
    """
    2x2 grouped-bar chart comparing train vs val on 4 metrics.

    Args:
        train_metrics / val_metrics: dicts from compute_metrics().
        state_cols: list of state variable names for x-axis.
        save_path: output PNG path.
        cfg: configuration dict.
    """
    _setup_style()
    metric_keys = [
        ("per_var_nrmse", "NRMSE"),
        ("per_var_mape", "MAPE (%)"),
        ("per_var_r2", "R²"),
        ("per_var_mae", "MAE"),
    ]
    fig, axes = plt.subplots(2, 2, figsize=cfg["figsize_grid"])
    x = np.arange(len(state_cols))
    w = 0.35

    for ax, (key, title) in zip(axes.flat, metric_keys):
        train_vals = train_metrics[key]
        val_vals = val_metrics[key]
        ax.bar(x - w / 2, train_vals, w, label="Train", color="#1f77b4", alpha=0.85)
        ax.bar(x + w / 2, val_vals, w, label="Val", color="#ff7f0e", alpha=0.85)
        ax.set_xticks(x)
        ax.set_xticklabels(state_cols, rotation=45, ha="right", fontsize=8)
        ax.set_title(title)
        ax.legend(fontsize=8)

    fig.suptitle("Metrics Comparison: Train vs Val", fontsize=13, fontweight="bold")
    fig.tight_layout()
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


def plot_freerun_vs_stepwise(fr_metrics, sw_metrics, state_cols, save_path, cfg):
    """
    1x2 grouped-bar chart: NRMSE and R² for freerun vs stepwise.

    Annotates improvement percentage on each bar pair.
    """
    _setup_style()
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=cfg["figsize_single"])
    x = np.arange(len(state_cols))
    w = 0.35

    # --- NRMSE ---
    fr_n = fr_metrics["per_var_nrmse"]
    sw_n = sw_metrics["per_var_nrmse"]
    ax1.bar(x - w / 2, fr_n, w, label="Free-run", color="#1f77b4", alpha=0.85)
    ax1.bar(x + w / 2, sw_n, w, label="Stepwise", color="#2ca02c", alpha=0.85)
    # Annotate improvement
    for j in range(len(state_cols)):
        if fr_n[j] > 1e-6:
            imp = (fr_n[j] - sw_n[j]) / fr_n[j] * 100
            ax1.annotate(f"{imp:+.0f}%", xy=(x[j] + w / 2, sw_n[j]),
                         fontsize=6, ha="center", va="bottom", color="green")
    ax1.set_xticks(x)
    ax1.set_xticklabels(state_cols, rotation=45, ha="right", fontsize=8)
    ax1.set_title("NRMSE")
    ax1.legend(fontsize=8)

    # --- R² ---
    fr_r = fr_metrics["per_var_r2"]
    sw_r = sw_metrics["per_var_r2"]
    ax2.bar(x - w / 2, fr_r, w, label="Free-run", color="#1f77b4", alpha=0.85)
    ax2.bar(x + w / 2, sw_r, w, label="Stepwise", color="#2ca02c", alpha=0.85)
    for j in range(len(state_cols)):
        if abs(fr_r[j]) > 1e-6:
            imp = (sw_r[j] - fr_r[j]) / abs(fr_r[j]) * 100
            ax2.annotate(f"{imp:+.0f}%", xy=(x[j] + w / 2, sw_r[j]),
                         fontsize=6, ha="center", va="bottom", color="green")
    ax2.set_xticks(x)
    ax2.set_xticklabels(state_cols, rotation=45, ha="right", fontsize=8)
    ax2.set_title("R²")
    ax2.legend(fontsize=8)

    fig.suptitle("Free-run vs Stepwise Prediction", fontsize=13, fontweight="bold")
    fig.tight_layout()
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


def plot_embeddings(models, clone_names, save_path, cfg):
    """
    2D PCA scatter of learned clone embeddings (averaged across ensemble).

    Shows ensemble mean position with ±1σ error bars.
    """
    _setup_style()
    n_clones = len(clone_names)

    # Extract embedding weights from each model: [n_models, n_clones, emb_dim]
    all_weights = []
    for net in models:
        w = net.clone_emb.weight.detach().cpu().numpy()[:n_clones]
        all_weights.append(w)
    all_weights = np.stack(all_weights, axis=0)  # [N, n_clones, D]

    mean_w = all_weights.mean(axis=0)  # [n_clones, D]
    std_w = all_weights.std(axis=0)    # [n_clones, D]

    # Dimensionality reduction
    if mean_w.shape[1] > 2:
        pca = PCA(n_components=2)
        coords = pca.fit_transform(mean_w)  # [n_clones, 2]
        # Project std through PCA components for error ellipse approximation
        std_proj = np.abs(std_w @ pca.components_.T)  # [n_clones, 2]
        xlabel = f"PC1 ({pca.explained_variance_ratio_[0]:.0%})"
        ylabel = f"PC2 ({pca.explained_variance_ratio_[1]:.0%})"
        method_label = "PCA"
    else:
        coords = mean_w[:, :2]
        std_proj = std_w[:, :2]
        xlabel, ylabel = "Dim 1", "Dim 2"
        method_label = "Raw"

    fig, ax = plt.subplots(figsize=(8, 6))
    cmap = plt.get_cmap("Set2")
    for i, name in enumerate(clone_names):
        color = cmap(i % 8)
        ax.errorbar(coords[i, 0], coords[i, 1],
                    xerr=std_proj[i, 0], yerr=std_proj[i, 1],
                    fmt="o", color=color, markersize=10, capsize=4,
                    label=name, alpha=0.9)
        ax.annotate(name, (coords[i, 0], coords[i, 1]),
                    textcoords="offset points", xytext=(8, 4), fontsize=8)

    ax.set_xlabel(xlabel)
    ax.set_ylabel(ylabel)
    ax.set_title(f"Clone Embeddings ({method_label})", fontsize=13, fontweight="bold")
    ax.legend(fontsize=8, loc="best")
    fig.tight_layout()
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


def plot_transfer_bars(results, save_path, cfg):
    """
    1x2 grouped-bar chart for transfer learning: 3 methods × 3 shots.

    Args:
        results: {method: {n_shot: {"nrmse": float, "r2": float}}}
        save_path: output PNG path.
        cfg: configuration dict.
    """
    _setup_style()
    methods = ["retrain", "embedding_only", "head_tuning"]
    shots = [0, 2, 4]

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))

    n_methods = len(methods)
    n_shots = len(shots)
    group_width = 0.8
    bar_width = group_width / n_shots
    group_positions = np.arange(n_methods)

    for metric_key, ax, title in [("nrmse", ax1, "NRMSE ↓"), ("r2", ax2, "R² ↑")]:
        for si, n_shot in enumerate(shots):
            vals = []
            for method in methods:
                v = results.get(method, {}).get(n_shot, {}).get(metric_key, 0.0)
                vals.append(v)
            offset = (si - (n_shots - 1) / 2) * bar_width
            bars = ax.bar(group_positions + offset, vals, bar_width,
                          label=f"{n_shot}-shot", color=_SHOT_COLORS[n_shot],
                          alpha=0.9, edgecolor="white", linewidth=0.5)
            # Value labels on top
            for bar, v in zip(bars, vals):
                ax.text(bar.get_x() + bar.get_width() / 2, bar.get_height(),
                        f"{v:.2f}", ha="center", va="bottom", fontsize=7)

        ax.set_xticks(group_positions)
        ax.set_xticklabels([_METHOD_LABELS[m] for m in methods], fontsize=10)
        ax.set_title(title, fontsize=12)
        ax.legend(fontsize=9)

    fig.suptitle("Transfer Learning: Few-Shot Adaptation", fontsize=13, fontweight="bold")
    fig.tight_layout()
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


def plot_stepwise_vs_freerun_trajectories(
    models, data, exp_ids, stats, cfg, device, save_path,
):
    """
    Overlay free-run and stepwise trajectories on the same axes.

    Layout: n_rows × n_cols (rows = experiments, cols = state variables).
    Blue = free-run, green = stepwise, red = observed.
    """
    _setup_style()
    state_cols = cfg["state_cols"]
    plot_ids = exp_ids[:min(3, len(exp_ids))]
    n_rows = len(plot_ids)
    n_cols = len(state_cols)

    fig, axes = plt.subplots(
        n_rows, n_cols, figsize=(3.5 * n_cols, 3 * n_rows), squeeze=False,
    )

    for row, eid in enumerate(plot_ids):
        batch = make_batch([eid], data, device)

        # Free-run
        fr_mean, fr_std, _, fr_t = solve_ensemble(models, batch, stats, cfg)
        fr_t_np = fr_t.cpu().numpy()
        fr_mean_np = fr_mean[0].cpu().numpy()
        fr_std_np = fr_std[0].cpu().numpy()

        # Stepwise
        sw_mean, sw_std, _, sw_t, reset_times = solve_ensemble_stepwise(
            models, batch, stats, cfg,
        )
        sw_t_np = sw_t.cpu().numpy()
        sw_mean_np = sw_mean[0].cpu().numpy()
        sw_std_np = sw_std[0].cpu().numpy()

        # Observed
        obs_t = batch.times[0].cpu().numpy()
        obs_y = batch.states[0].cpu().numpy()
        obs_m = batch.obs_masks[0].cpu().numpy()

        for col in range(n_cols):
            ax = axes[row, col]

            # Free-run band
            ax.fill_between(
                fr_t_np,
                fr_mean_np[:, col] - fr_std_np[:, col],
                fr_mean_np[:, col] + fr_std_np[:, col],
                alpha=0.2, color="#1f77b4",
            )
            ax.plot(
                fr_t_np, fr_mean_np[:, col],
                color="#1f77b4", linewidth=1.5, label="Free-run",
            )

            # Stepwise band
            ax.fill_between(
                sw_t_np,
                sw_mean_np[:, col] - sw_std_np[:, col],
                sw_mean_np[:, col] + sw_std_np[:, col],
                alpha=0.2, color="#2ca02c",
            )
            ax.plot(
                sw_t_np, sw_mean_np[:, col],
                color="#2ca02c", linewidth=1.5, label="Stepwise",
            )

            # Reset vertical lines
            for rt in reset_times:
                ax.axvline(rt, color="gray", linestyle="--", alpha=0.5, linewidth=0.8)

            # Observed scatter
            valid = obs_m[:, col] > 0.5
            ax.scatter(
                obs_t[valid], obs_y[valid, col],
                color="red", s=20, zorder=5, marker="o",
                edgecolors="darkred", linewidths=0.5, label="Observed",
            )

            if row == 0:
                ax.set_title(state_cols[col], fontsize=10, fontweight="bold")
            if col == 0:
                ax.set_ylabel(eid, fontsize=8)
            ax.tick_params(labelsize=7)
            if row == 0 and col == n_cols - 1:
                ax.legend(fontsize=6, loc="upper right")

    fig.suptitle(
        "Stepwise vs Free-run Trajectories (Ensemble Mean ± 1σ)",
        fontsize=13, fontweight="bold",
    )
    fig.tight_layout()
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


def plot_transfer_embeddings(
    transfer_results, base_clone_names, save_path, cfg,
):
    """
    1×3 PCA scatter of base vs holdout clone embeddings for each adaptation method.

    Extracts clone_emb.weight from the 4-shot adapted models (ensemble mean),
    fits PCA on base clones, and projects the holdout clone onto the same space.
    """
    _setup_style()
    adapted_models = transfer_results.get("models")
    if adapted_models is None:
        logger.warning("No 4-shot models available; skipping transfer embedding plot.")
        return

    methods = ["retrain", "embedding_only", "head_tuning", "full_head_tuning"]
    method_labels = {"retrain": "Retrain", "embedding_only": "Embed-Only", "head_tuning": "Head-Tune"}
    n_base = len(base_clone_names)

    fig, axes = plt.subplots(1, 4, figsize=(22, 5))

    for ax, method in zip(axes, methods):
        method_models = adapted_models.get(method)
        if method_models is None:
            ax.set_title(method_labels[method] + " (N/A)")
            continue

        # Extract embeddings: each model has n_base+1 rows (last = holdout)
        all_weights = []
        for net in method_models:
            w = net.clone_emb.weight.detach().cpu().numpy()
            all_weights.append(w)
        all_weights = np.stack(all_weights, axis=0)  # [N, n_base+1, D]

        mean_w = all_weights.mean(axis=0)  # [n_base+1, D]
        base_w = mean_w[:n_base]           # [n_base, D]
        holdout_w = mean_w[n_base:n_base + 1]  # [1, D]

        # PCA fit on base, transform all
        pca = PCA(n_components=2)
        base_coords = pca.fit_transform(base_w)       # [n_base, 2]
        holdout_coords = pca.transform(holdout_w)      # [1, 2]

        # Base clones — gray circles
        ax.scatter(
            base_coords[:, 0], base_coords[:, 1],
            c="lightgray", edgecolors="gray", s=60, zorder=3, label="Base clones",
        )
        for i, name in enumerate(base_clone_names):
            ax.annotate(
                name, (base_coords[i, 0], base_coords[i, 1]),
                textcoords="offset points", xytext=(5, 3), fontsize=6,
                color="gray",
            )

        # Holdout clone — red star
        ax.scatter(
            holdout_coords[:, 0], holdout_coords[:, 1],
            c="red", marker="*", s=200, zorder=5, edgecolors="darkred",
            linewidths=0.5, label="Holdout",
        )

        ax.set_xlabel(f"PC1 ({pca.explained_variance_ratio_[0]:.0%})")
        ax.set_ylabel(f"PC2 ({pca.explained_variance_ratio_[1]:.0%})")
        ax.set_title(method_labels[method], fontsize=12, fontweight="bold")
        ax.legend(fontsize=8, loc="best")

    fig.suptitle(
        "Transfer Embeddings: Base vs Holdout (4-shot)",
        fontsize=13, fontweight="bold",
    )
    fig.tight_layout()
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


def plot_predictions(models, data, exp_ids, stats, cfg, device, save_path):
    """
    Prediction trajectories for selected experiments (stakeholder view).

    Shows ensemble mean ± 1σ with observed data overlay for all states.
    """
    _setup_style()
    all_states = cfg["state_cols"]
    state_indices = list(range(len(all_states)))
    shown_states = list(all_states)

    plot_ids = exp_ids[:min(3, len(exp_ids))]
    n_rows = len(plot_ids)
    n_cols = len(shown_states)

    fig, axes = plt.subplots(n_rows, n_cols, figsize=(3.5 * n_cols, 3 * n_rows),
                             squeeze=False)

    for row, eid in enumerate(plot_ids):
        batch = make_batch([eid], data, device)
        mean_pred, std_pred, _, t_eval = solve_ensemble(models, batch, stats, cfg)

        # Denormalize times and get numpy
        t_np = t_eval.cpu().numpy()
        mean_np = mean_pred[0].cpu().numpy()  # [T, n_states]
        std_np = std_pred[0].cpu().numpy()

        obs_t = batch.times[0].cpu().numpy()
        obs_y = batch.states[0].cpu().numpy()
        obs_m = batch.obs_masks[0].cpu().numpy()

        for col, si in enumerate(state_indices):
            ax = axes[row, col]
            # Prediction band
            ax.fill_between(t_np, mean_np[:, si] - std_np[:, si],
                            mean_np[:, si] + std_np[:, si],
                            alpha=0.25, color="#1f77b4")
            ax.plot(t_np, mean_np[:, si], color="#1f77b4", linewidth=1.5,
                    label="Prediction")
            # Observed data
            valid = obs_m[:, si] > 0.5
            ax.scatter(obs_t[valid], obs_y[valid, si], color="red", s=20,
                       zorder=5, label="Observed", marker="o", edgecolors="darkred",
                       linewidths=0.5)
            if row == 0:
                ax.set_title(shown_states[col], fontsize=10, fontweight="bold")
            if col == 0:
                ax.set_ylabel(eid, fontsize=8)
            ax.tick_params(labelsize=7)
            if row == 0 and col == n_cols - 1:
                ax.legend(fontsize=7, loc="upper right")

    fig.suptitle("Prediction Examples (Ensemble Mean ± 1σ)", fontsize=13, fontweight="bold")
    fig.tight_layout()
    fig.savefig(save_path, dpi=cfg["dpi"], bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved %s", save_path)


