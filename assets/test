def main():
    parser = argparse.ArgumentParser(description="BioPFM EDA Report Generator")
    parser.add_argument("--data", required=True, help="Path to CSV dataset")
    parser.add_argument("--output", default="eda_results", help="Output directory")
    parser.add_argument("--n-clusters", type=int, default=5, help="KMeans clusters for PCA")
    parser.add_argument("--dpi", type=int, default=150, help="Figure DPI")
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s [%(levelname)s] %(message)s",
        datefmt="%H:%M:%S",
    )

    setup_style()
    os.makedirs(args.output, exist_ok=True)

    df = load_data(args.data)
    kpi_df = compute_experiment_kpis(df)

    logger.info("=== Generating plots ===")
    plot_clone_run_counts(df, args.output)
    plot_trajectory_overlays(df, args.output)
    plot_kpi_correlation(kpi_df, args.output)
    plot_raw_correlation(df, args.output)
    plot_clone_comparison(kpi_df, args.output)
    plot_feeding_strategy(df, kpi_df, args.output)
    plot_pca_clustering(df, n_clusters=args.n_clusters, output_dir=args.output)

    logger.info("=== EDA report complete → %s/ ===", args.output)


if __name__ == "__main__":
    main()
