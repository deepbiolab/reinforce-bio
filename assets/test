def load_and_preprocess(csv_path, cfg):
    """
    Load a CSV dataset and convert to per-experiment ExperimentData dicts.

    Returns:
        data: dict {exp_id: ExperimentData}
        vocab: dict with clone_to_idx, idx_to_clone, n_clones, clone_names
    """
    df = pd.read_csv(csv_path)

    # --- Validate required columns ---
    required = (
        [cfg["time_col"], cfg["exp_id_col"], cfg["product_id_col"], cfg["volume_col"]]
        + cfg["state_cols"] + cfg["control_cols"] + cfg["feed_cols"] + cfg["static_cols"]
    )
    missing = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"Missing columns in CSV: {missing}")

    # --- Build clone vocabulary (sorted for reproducibility) ---
    clone_names = sorted(df[cfg["product_id_col"]].unique().tolist())
    clone_to_idx = {name: idx for idx, name in enumerate(clone_names)}
    vocab = {
        "clone_to_idx": clone_to_idx,
        "idx_to_clone": {idx: name for name, idx in clone_to_idx.items()},
        "n_clones": len(clone_names),
        "clone_names": clone_names,
    }

    state_cols = cfg["state_cols"]
    control_cols = cfg["control_cols"]
    feed_cols = cfg["feed_cols"]
    static_cols = cfg["static_cols"]
    zero_init = set(cfg["zero_init_states"])

    data = {}
    for exp_id, grp in df.groupby(cfg["exp_id_col"]):
        grp = grp.sort_values(cfg["time_col"]).reset_index(drop=True)
        n_steps = len(grp)

        # Time in hours
        times = grp[cfg["time_col"]].values.astype(np.float32)

        # States and observation masks
        raw_states = grp[state_cols].values  # (T, n_states)
        obs_masks = (~np.isnan(raw_states)).astype(np.float32)
        states = np.nan_to_num(raw_states, nan=0.0).astype(np.float32)

        # Initial states: y0
        initial_states = np.zeros(len(state_cols), dtype=np.float32)
        for j, col in enumerate(state_cols):
            if col in zero_init:
                # If first measurement is NaN, start at 0; otherwise use it
                first_val = raw_states[0, j]
                initial_states[j] = 0.0 if np.isnan(first_val) else first_val
            else:
                # First non-NaN value (fall back to 0)
                valid = raw_states[:, j]
                non_nan = valid[~np.isnan(valid)]
                initial_states[j] = non_nan[0] if len(non_nan) > 0 else 0.0

        # Controls (forward fill NaN, then back fill remaining)
        ctrl_df = grp[control_cols].ffill().bfill()
        controls = ctrl_df.values.astype(np.float32)

        # Time deltas for rate computation
        dt = np.diff(times)  # (T-1,)
        if len(dt) == 0:
            dt = np.array([1.0], dtype=np.float32)
        dt_extended = np.append(dt, dt[-1])  # (T,) — last point reuses previous dt
        dt_extended = np.maximum(dt_extended, 1e-6)  # avoid division by zero

        # Feed rates: amount / dt → rate (amount per hour)
        feed_amounts = grp[feed_cols].fillna(0.0).values.astype(np.float32)  # (T, n_feeds)
        feed_rates = feed_amounts / dt_extended[:, None]

        # Volume rates: max(V[i+1]-V[i], 0) / dt
        vol = grp[cfg["volume_col"]].values.astype(np.float32)
        vol_diff = np.diff(vol)  # (T-1,)
        vol_diff = np.append(vol_diff, vol_diff[-1] if len(vol_diff) > 0 else 0.0)
        vol_rates = np.maximum(vol_diff, 0.0) / dt_extended
        vol_rates = vol_rates.astype(np.float32)

        initial_vol = vol[0]

        # Clone info
        clone_name = grp[cfg["product_id_col"]].iloc[0]
        clone_idx = clone_to_idx[clone_name]

        # Static features (from first row)
        statics = grp[static_cols].iloc[0].values.astype(np.float32)

        data[exp_id] = ExperimentData(
            times=times,
            states=states,
            obs_masks=obs_masks,
            controls=controls,
            feed_rates=feed_rates,
            vol_rates=vol_rates,
            initial_vol=np.float32(initial_vol),
            initial_states=initial_states,
            clone_name=clone_name,
            clone_idx=clone_idx,
            statics=statics,
        )

    logger.info("Loaded %d experiments from %s", len(data), csv_path)
    return data, vocab


def split_holdout(data, holdout_clone, cfg):
    """Split data into base (training pool) and holdout (held-out clone)."""
    base_data = {}
    holdout_data = {}
    for exp_id, exp in data.items():
        if exp.clone_name == holdout_clone:
            holdout_data[exp_id] = exp
        else:
            base_data[exp_id] = exp
    logger.info(
        "Split: %d base experiments, %d holdout experiments (clone=%s)",
        len(base_data), len(holdout_data), holdout_clone,
    )
    if len(holdout_data) == 0:
        raise ValueError(f"Holdout clone '{holdout_clone}' not found in data")
    return base_data, holdout_data


def split_train_val(base_data, val_ratio, seed):
    """
    Product-stratified train/val split. Ensures at least 1 val per clone
    when possible.

    Returns:
        (train_ids, val_ids) — lists of experiment IDs.
    """
    rng = np.random.RandomState(seed)

    # Group experiment IDs by clone
    clone_groups = {}
    for exp_id, exp in base_data.items():
        clone_groups.setdefault(exp.clone_name, []).append(exp_id)

    train_ids, val_ids = [], []
    for clone_name, ids in sorted(clone_groups.items()):
        ids = sorted(ids)  # reproducibility
        rng.shuffle(ids)
        n_val = max(1, int(len(ids) * val_ratio))
        if len(ids) <= 1:
            # Only one experiment: put in train (cannot split further)
            train_ids.extend(ids)
        else:
            val_ids.extend(ids[:n_val])
            train_ids.extend(ids[n_val:])

    logger.info("Train/val split: %d train, %d val", len(train_ids), len(val_ids))
    return train_ids, val_ids


def compute_stats(data, train_ids, cfg):
    """
    Compute normalization statistics (mean/std) from training data only.

    Returns dict of torch tensors: state_mean, state_std, control_mean,
    control_std, static_mean, static_std.
    """
    state_cols = cfg["state_cols"]
    control_cols = cfg["control_cols"]
    static_cols = cfg["static_cols"]

    # Gather arrays from training experiments
    all_controls = []
    all_statics = []
    # Collect observed-only state values per variable (avoid NaN-filled zeros)
    n_states = len(cfg["state_cols"])
    obs_per_var = [[] for _ in range(n_states)]
    for eid in train_ids:
        exp = data[eid]
        for j in range(n_states):
            mask_j = exp.obs_masks[:, j] > 0.5
            if mask_j.any():
                obs_per_var[j].append(exp.states[mask_j, j])
        all_controls.append(exp.controls)
        all_statics.append(exp.statics)

    # State stats from observed values only
    s_mean_list, s_std_list = [], []
    for j in range(n_states):
        if obs_per_var[j]:
            vals = np.concatenate(obs_per_var[j])
            s_mean_list.append(vals.mean())
            s_std_list.append(max(vals.std(), 1e-6))
        else:
            s_mean_list.append(0.0)
            s_std_list.append(1.0)
    s_mean = torch.tensor(s_mean_list, dtype=torch.float32)
    s_std = torch.tensor(s_std_list, dtype=torch.float32)

    controls_cat = np.concatenate(all_controls, axis=0)   # (N, n_ctrl)
    statics_cat = np.stack(all_statics, axis=0)           # (M, n_static)

    def _mean_std(arr):
        m = arr.mean(axis=0).astype(np.float32)
        s = arr.std(axis=0).astype(np.float32)
        s = np.maximum(s, 1e-6)  # floor to avoid division by zero
        return torch.from_numpy(m), torch.from_numpy(s)
    c_mean, c_std = _mean_std(controls_cat)
    st_mean, st_std = _mean_std(statics_cat)

    stats = {
        "state_mean": s_mean,
        "state_std": s_std,
        "control_mean": c_mean,
        "control_std": c_std,
        "static_mean": st_mean,
        "static_std": st_std,
    }
    logger.info("Computed normalization stats from %d training experiments", len(train_ids))
    return stats


def make_batch(exp_ids, data, device):
    """
    Collate a list of experiments into a padded BatchData on the given device.

    Padding strategy:
      - times/states/obs_masks/feed_rates/vol_rates: zero-padded
      - controls: replicate last value for padded positions
      - pad_masks: 1 for real timesteps, 0 for padding
    """
    experiments = [data[eid] for eid in exp_ids]
    max_len = max(len(exp.times) for exp in experiments)
    n_states = experiments[0].states.shape[1]
    n_ctrl = experiments[0].controls.shape[1]
    n_feeds = experiments[0].feed_rates.shape[1]
    n_static = len(experiments[0].statics)
    batch_size = len(experiments)

    # Pre-allocate numpy arrays
    times = np.zeros((batch_size, max_len), dtype=np.float32)
    states = np.zeros((batch_size, max_len, n_states), dtype=np.float32)
    obs_masks = np.zeros((batch_size, max_len, n_states), dtype=np.float32)
    pad_masks = np.zeros((batch_size, max_len), dtype=np.float32)
    controls = np.zeros((batch_size, max_len, n_ctrl), dtype=np.float32)
    feed_rates = np.zeros((batch_size, max_len, n_feeds), dtype=np.float32)
    vol_rates = np.zeros((batch_size, max_len), dtype=np.float32)
    initial_states = np.zeros((batch_size, n_states), dtype=np.float32)
    initial_vols = np.zeros(batch_size, dtype=np.float32)
    clone_indices = np.zeros(batch_size, dtype=np.int64)
    statics = np.zeros((batch_size, n_static), dtype=np.float32)

    for i, exp in enumerate(experiments):
        t = len(exp.times)
        times[i, :t] = exp.times
        states[i, :t] = exp.states
        obs_masks[i, :t] = exp.obs_masks
        pad_masks[i, :t] = 1.0
        controls[i, :t] = exp.controls
        feed_rates[i, :t] = exp.feed_rates
        vol_rates[i, :t] = exp.vol_rates
        initial_states[i] = exp.initial_states
        initial_vols[i] = exp.initial_vol
        clone_indices[i] = exp.clone_idx
        statics[i] = exp.statics

        # Pad controls by replicating last value
        if t < max_len:
            controls[i, t:] = exp.controls[-1]

    return BatchData(
        times=torch.from_numpy(times).to(device),
        initial_states=torch.from_numpy(initial_states).to(device),
        states=torch.from_numpy(states).to(device),
        obs_masks=torch.from_numpy(obs_masks).to(device),
        pad_masks=torch.from_numpy(pad_masks).to(device),
        controls=torch.from_numpy(controls).to(device),
        feed_rates=torch.from_numpy(feed_rates).to(device),
        vol_rates=torch.from_numpy(vol_rates).to(device),
        initial_vols=torch.from_numpy(initial_vols).to(device),
        clone_indices=torch.from_numpy(clone_indices).to(device),
        statics=torch.from_numpy(statics).to(device),
    )


