#!/usr/bin/env python3
"""
eda_report.py — Exploratory Data Analysis report for BioPFM datasets.

Generates publication-ready EDA visualizations in Datahow hybrid-modeling style.
No torch dependency — pure data analysis with numpy, pandas, sklearn, matplotlib, seaborn.

Usage:
    uv run python scripts/eda_report.py --data datasets/nano_legacy.csv --output eda_results/
    uv run python scripts/eda_report.py --data /path/to/real_data.csv --output real_eda/ --n-clusters 4
"""

import argparse
import logging
import os
import sys

import matplotlib.patches as mpatches
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import seaborn as sns
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.preprocessing import MinMaxScaler, StandardScaler

logger = logging.getLogger(__name__)

# ============================================================
# Column constants (matching nano_legacy.csv / real data)
# ============================================================

TIME_COL = "time"
EXP_ID_COL = "exp_id"
CLONE_COL = "clone_name"

STATE_COLS = ["vcd", "glc", "lac", "amm", "titer", "osmo", "viability", "pco2", "po2"]
CONTROL_COLS = ["temperature", "pH", "do"]
FEED_COLS = ["feed_glc", "feed_7a", "feed_7b"]
VOLUME_COL = "working_vol"

REQUIRED_COLS = [TIME_COL, EXP_ID_COL, CLONE_COL]

# Pretty labels for plots
STATE_LABELS = {
    "vcd": "VCD (10⁶ cells/mL)", "glc": "Glucose (mM)", "lac": "Lactate (mM)",
    "amm": "Ammonium (mM)", "titer": "Titer (mg/L)", "osmo": "Osmolality (mOsm/kg)",
    "viability": "Viability (%)", "pco2": "pCO₂ (mmHg)", "po2": "pO₂ (mmHg)",
}
FEED_LABELS = {
    "feed_glc": "Glucose Feed (L)", "feed_7a": "Feed 7a (L)", "feed_7b": "Feed 7b (L)",
}

# Extended marker list for PCA / scatter (16 distinct shapes)
MARKER_LIST = ["o", "s", "^", "D", "v", "P", "*", "X", "h", "p", "d", ">", "<", "H", "8", "+"]
# Linestyle cycle for trajectory differentiation
LINESTYLE_LIST = ["-", "--", "-.", ":"]


# ============================================================
# Style & utilities
# ============================================================

def setup_style():
    """Apply clean publication-ready matplotlib style."""
    plt.rcParams.update({
        "figure.facecolor": "white",
        "axes.facecolor": "white",
        "axes.grid": True,
        "grid.alpha": 0.3,
        "axes.spines.top": False,
        "axes.spines.right": False,
        "font.size": 10,
    })


def _get_clone_colors(clone_names):
    """Return a dict mapping clone_name -> color with good separation.

    <=10 clones: tab10, 11-20: tab20, >20: nipy_spectral (evenly sampled,
    avoiding dark edges).
    """
    names = sorted(clone_names)
    n = len(names)
    if n <= 10:
        cmap = plt.get_cmap("tab10")
        return {name: cmap(i) for i, name in enumerate(names)}
    if n <= 20:
        cmap = plt.get_cmap("tab20")
        return {name: cmap(i) for i, name in enumerate(names)}
    # >20: sample nipy_spectral avoiding dark edges (0.05 .. 0.95)
    cmap = plt.get_cmap("nipy_spectral")
    positions = np.linspace(0.05, 0.95, n)
    return {name: cmap(pos) for name, pos in zip(names, positions)}


def _get_clone_linestyles(clone_names):
    """Return a dict mapping clone_name -> linestyle (cycling)."""
    names = sorted(clone_names)
    return {name: LINESTYLE_LIST[i % len(LINESTYLE_LIST)] for i, name in enumerate(names)}


def _adaptive_ncol(n_items, max_ncol=8):
    """Choose ncol for legend based on item count."""
    if n_items <= 5:
        return n_items
    if n_items <= 10:
        return 5
    return min(max_ncol, (n_items + 1) // 2)


def save_figure(fig, path, dpi=150):
    """Save figure, close it, and log the path."""
    fig.savefig(path, dpi=dpi, bbox_inches="tight")
    plt.close(fig)
    logger.info("Saved: %s", path)


# ============================================================
# Data loading
# ============================================================

def load_data(csv_path):
    """Load CSV and validate required columns. Returns DataFrame."""
    df = pd.read_csv(csv_path)
    logger.info("Loaded %s: shape=%s", csv_path, df.shape)

    # Check required columns
    missing = [c for c in REQUIRED_COLS if c not in df.columns]
    if missing:
        logger.error("Missing required columns: %s", missing)
        sys.exit(1)

    # Report available columns
    available_states = [c for c in STATE_COLS if c in df.columns]
    available_feeds = [c for c in FEED_COLS if c in df.columns]
    available_controls = [c for c in CONTROL_COLS if c in df.columns]
    logger.info("States: %s, Feeds: %s, Controls: %s",
                available_states, available_feeds, available_controls)

    clones = df[CLONE_COL].unique()
    n_exp = df[EXP_ID_COL].nunique()
    logger.info("Clones: %s (%d), Experiments: %d", list(clones), len(clones), n_exp)

    # NaN diagnostics
    nan_pct = df.isnull().mean()
    cols_with_nan = nan_pct[nan_pct > 0]
    if len(cols_with_nan) > 0:
        logger.info("Columns with NaN: %s", {c: f"{v:.1%}" for c, v in cols_with_nan.items()})

    return df


# ============================================================
# KPI computation
# ============================================================

def compute_experiment_kpis(df):
    """Compute per-experiment KPIs. Returns DataFrame indexed by exp_id."""
    records = []

    for exp_id, grp in df.groupby(EXP_ID_COL):
        grp = grp.sort_values(TIME_COL)
        clone = grp[CLONE_COL].iloc[0]
        rec = {EXP_ID_COL: exp_id, CLONE_COL: clone}

        # Peak VCD
        if "vcd" in grp.columns:
            rec["peak_vcd"] = grp["vcd"].max()
        else:
            rec["peak_vcd"] = np.nan

        # Final titer (last non-NaN value)
        if "titer" in grp.columns:
            titer_valid = grp["titer"].dropna()
            rec["final_titer"] = titer_valid.iloc[-1] if len(titer_valid) > 0 else np.nan
        else:
            rec["final_titer"] = np.nan

        # Max lactate
        if "lac" in grp.columns:
            rec["max_lac"] = grp["lac"].max()
        else:
            rec["max_lac"] = np.nan

        # IVCD (trapezoidal integration, cell-days/mL)
        if "vcd" in grp.columns:
            vcd_time = grp[[TIME_COL, "vcd"]].dropna()
            if len(vcd_time) >= 2:
                rec["ivcd"] = float(np.trapezoid(
                    y=vcd_time["vcd"].values, x=vcd_time[TIME_COL].values
                )) / 24.0
            else:
                rec["ivcd"] = np.nan
        else:
            rec["ivcd"] = np.nan

        # mu_max (max specific growth rate from consecutive positive VCD)
        if "vcd" in grp.columns:
            vcd_vals = grp[["vcd", TIME_COL]].dropna()
            vcd_arr = vcd_vals["vcd"].values
            t_arr = vcd_vals[TIME_COL].values
            mu_vals = []
            for i in range(len(vcd_arr) - 1):
                if vcd_arr[i] > 0 and vcd_arr[i + 1] > 0:
                    dt = t_arr[i + 1] - t_arr[i]
                    if dt > 0:
                        mu_vals.append(np.log(vcd_arr[i + 1] / vcd_arr[i]) / dt)
            rec["mu_max"] = max(mu_vals) if mu_vals else np.nan
        else:
            rec["mu_max"] = np.nan

        # Volumetric productivity (mg/L/day)
        total_hours = grp[TIME_COL].max() - grp[TIME_COL].min()
        if not np.isnan(rec.get("final_titer", np.nan)) and total_hours > 0:
            rec["vol_prod"] = rec["final_titer"] / (total_hours / 24.0)
        else:
            rec["vol_prod"] = np.nan

        # Cumulative glucose feed
        if "feed_glc" in grp.columns:
            rec["cum_feed_glc"] = grp["feed_glc"].fillna(0).sum()
        else:
            rec["cum_feed_glc"] = np.nan

        records.append(rec)

    kpi_df = pd.DataFrame(records)

    # Drop rows where both peak_vcd and final_titer are NaN (useless experiments)
    mask = kpi_df["peak_vcd"].isna() & kpi_df["final_titer"].isna()
    n_dropped = mask.sum()
    if n_dropped > 0:
        logger.warning("Dropped %d experiments with no peak_vcd and no final_titer", n_dropped)
        kpi_df = kpi_df[~mask].reset_index(drop=True)

    logger.info("KPI table: %d experiments, columns=%s", len(kpi_df), list(kpi_df.columns))
    return kpi_df


# ============================================================
# Plot 00: Clone run counts (NEW)
# ============================================================

def plot_clone_run_counts(df, output_dir):
    """Bar chart of experiment count per clone, sorted descending."""
    counts = df.groupby(CLONE_COL)[EXP_ID_COL].nunique().sort_values(ascending=False)
    clone_colors = _get_clone_colors(counts.index)

    fig, ax = plt.subplots(figsize=(max(6, len(counts) * 0.5), 4))
    bars = ax.bar(range(len(counts)), counts.values,
                  color=[clone_colors[c] for c in counts.index])

    # Annotate counts on bars
    for bar, val in zip(bars, counts.values):
        ax.text(bar.get_x() + bar.get_width() / 2, bar.get_height() + 0.3,
                str(val), ha="center", va="bottom", fontsize=9, fontweight="bold")

    ax.set_xticks(range(len(counts)))
    ax.set_xticklabels(counts.index, rotation=45, ha="right", fontsize=9)
    ax.set_xlabel("Clone")
    ax.set_ylabel("Number of Experiments")
    ax.set_title("Experiment Count per Clone")
    fig.tight_layout()
    save_figure(fig, os.path.join(output_dir, "00_clone_run_counts.png"))


# ============================================================
# Plot 01: Trajectory overlays
# ============================================================

def plot_trajectory_overlays(df, output_dir):
    """2xN grid of state variable trajectories, colored by clone."""
    available = [c for c in STATE_COLS if c in df.columns and c != "titer"]
    if not available:
        logger.warning("No state columns found; skipping trajectory plot.")
        return

    clone_names = df[CLONE_COL].unique()
    clone_colors = _get_clone_colors(clone_names)
    clone_ls = _get_clone_linestyles(clone_names)
    n_plots = len(available)
    n_cols = 4
    n_rows = (n_plots + n_cols - 1) // n_cols

    fig, axes = plt.subplots(n_rows, n_cols, figsize=(4 * n_cols, 3.5 * n_rows))
    axes = np.atleast_2d(axes)

    for idx, col in enumerate(available):
        ax = axes[idx // n_cols, idx % n_cols]
        for exp_id, grp in df.groupby(EXP_ID_COL):
            clone = grp[CLONE_COL].iloc[0]
            ax.plot(grp[TIME_COL], grp[col], color=clone_colors[clone],
                    alpha=0.3, linewidth=1.0, linestyle=clone_ls[clone])
        ax.set_xlabel("Time (h)")
        ax.set_ylabel(STATE_LABELS.get(col, col))
        ax.set_title(col.upper())

    # Hide unused axes
    for idx in range(n_plots, n_rows * n_cols):
        axes[idx // n_cols, idx % n_cols].set_visible(False)

    # Legend at figure bottom outside
    handles = [mpatches.Patch(color=clone_colors[n], label=n) for n in sorted(clone_names)]
    ncol = _adaptive_ncol(len(handles))
    fig.legend(handles=handles, loc="lower center", fontsize=8, ncol=ncol,
               bbox_to_anchor=(0.5, -0.02))
    fig.tight_layout(rect=[0, 0.06, 1, 1])
    save_figure(fig, os.path.join(output_dir, "01_trajectory_overlays.png"))


# ============================================================
# Plot 02a: KPI correlation heatmap
# ============================================================

def plot_kpi_correlation(kpi_df, output_dir):
    """Correlation heatmap (02a) of KPIs."""
    numeric_cols = [c for c in ["peak_vcd", "final_titer", "ivcd", "max_lac",
                                "mu_max", "vol_prod", "cum_feed_glc"]
                    if c in kpi_df.columns]
    if len(numeric_cols) < 2:
        logger.warning("Not enough KPI columns for correlation; skipping.")
        return

    kpi_numeric = kpi_df[numeric_cols].dropna(axis=1, how="all")

    corr = kpi_numeric.corr()
    fig, ax = plt.subplots(figsize=(8, 6))
    sns.heatmap(corr, annot=True, fmt=".2f", cmap="RdBu_r", center=0,
                vmin=-1, vmax=1, square=True, ax=ax, linewidths=0.5)
    ax.set_title("KPI Correlation Matrix")
    fig.text(0.5, -0.02,
             "Pearson correlation between per-run KPIs. Strong positive (red) or negative (blue) indicates linear association.",
             ha="center", fontsize=9, style="italic", color="gray")
    save_figure(fig, os.path.join(output_dir, "02a_kpi_correlation_heatmap.png"))


# ============================================================
# Plot 02c: Raw data correlation heatmap (NEW)
# ============================================================

def plot_raw_correlation(df, output_dir):
    """Correlation heatmap of all numeric process columns (states + controls + feeds)."""
    candidate_cols = STATE_COLS + CONTROL_COLS + FEED_COLS
    available = [c for c in candidate_cols if c in df.columns]
    if len(available) < 2:
        logger.warning("Not enough numeric columns for raw correlation; skipping.")
        return

    corr = df[available].corr()
    fig, ax = plt.subplots(figsize=(max(8, len(available) * 0.7), max(6, len(available) * 0.55)))
    sns.heatmap(corr, annot=True, fmt=".2f", cmap="RdBu_r", center=0,
                vmin=-1, vmax=1, square=True, ax=ax, linewidths=0.5)
    ax.set_title("Raw Data Correlation Matrix (All Numeric Columns)")
    save_figure(fig, os.path.join(output_dir, "02c_raw_correlation_heatmap.png"))


# ============================================================
# Plot 03a/03b: Clone comparison
# ============================================================

def plot_clone_comparison(kpi_df, output_dir):
    """Box/violin plots (03a) and radar chart (03b) for clone KPI comparison."""
    # 03a: Clone KPI comparison
    violin_cols = [c for c in ["final_titer", "peak_vcd", "ivcd", "max_lac"]
                   if c in kpi_df.columns]
    violin_labels = {
        "final_titer": "Final Titer (mg/L)", "peak_vcd": "Peak VCD (10⁶/mL)",
        "ivcd": "IVCD (10⁶ cell·day/mL)", "max_lac": "Max Lactate (mM)",
    }
    if violin_cols and CLONE_COL in kpi_df.columns:
        n_clones = kpi_df[CLONE_COL].nunique()
        n_kpis = len(violin_cols)

        if n_clones > 10:
            # Horizontal boxplots — height scales with clone count
            fig_h = max(4, n_clones * 0.4)
            fig, axes = plt.subplots(1, n_kpis, figsize=(5 * n_kpis, fig_h))
            if n_kpis == 1:
                axes = [axes]
            clone_order = sorted(kpi_df[CLONE_COL].unique())
            for ax, col in zip(axes, violin_cols):
                plot_df = kpi_df[[CLONE_COL, col]].dropna()
                sns.boxplot(data=plot_df, y=CLONE_COL, x=col, order=clone_order,
                            hue=CLONE_COL, palette=_get_clone_colors(clone_order),
                            legend=False, ax=ax)
                ax.set_xlabel(violin_labels.get(col, col))
                ax.set_ylabel("")
                ax.set_title(col.replace("_", " ").title())
        else:
            # Vertical violins for <=10 clones
            fig, axes = plt.subplots(1, n_kpis, figsize=(4 * n_kpis, 4))
            if n_kpis == 1:
                axes = [axes]
            for ax, col in zip(axes, violin_cols):
                plot_df = kpi_df[[CLONE_COL, col]].dropna()
                sns.violinplot(data=plot_df, x=CLONE_COL, y=col, hue=CLONE_COL,
                               inner="box", palette="tab10", legend=False, ax=ax)
                ax.set_ylabel(violin_labels.get(col, col))
                ax.set_xlabel("")
                ax.set_title(col.replace("_", " ").title())
                ax.tick_params(axis="x", rotation=45)
                for label in ax.get_xticklabels():
                    label.set_ha("right")

        fig.suptitle("Clone KPI Comparison", fontsize=13, y=1.02)
        fig.text(0.5, -0.02,
                 "Distribution of KPIs per clone. Box shows IQR; wider spread indicates higher clone variability.",
                 ha="center", fontsize=9, style="italic", color="gray")
        fig.tight_layout()
        save_figure(fig, os.path.join(output_dir, "03a_clone_boxplots.png"))

    # 03b: Radar chart
    radar_cols = [c for c in ["peak_vcd", "final_titer", "ivcd", "max_lac", "mu_max", "vol_prod"]
                  if c in kpi_df.columns]
    if len(radar_cols) < 3 or CLONE_COL not in kpi_df.columns:
        logger.warning("Not enough KPI columns for radar chart; skipping.")
        return

    # Compute clone medians and normalize
    clone_medians = kpi_df.groupby(CLONE_COL)[radar_cols].median()

    # Truncate to top-8 by final_titer median if too many clones
    title_suffix = ""
    if len(clone_medians) > 8:
        sort_col = "final_titer" if "final_titer" in radar_cols else radar_cols[0]
        top_clones = clone_medians[sort_col].nlargest(8).index
        clone_medians = clone_medians.loc[top_clones]
        title_suffix = f" (Top 8 by {sort_col})"

    scaler = MinMaxScaler()
    normalized = pd.DataFrame(
        scaler.fit_transform(clone_medians),
        index=clone_medians.index, columns=clone_medians.columns,
    )

    # Plot
    n_vars = len(radar_cols)
    angles = np.linspace(0, 2 * np.pi, n_vars, endpoint=False).tolist()
    angles += angles[:1]  # close polygon

    clone_colors = _get_clone_colors(normalized.index)
    fig, ax = plt.subplots(figsize=(7, 7), subplot_kw={"polar": True})

    for clone_name in normalized.index:
        values = normalized.loc[clone_name].values.tolist()
        values += values[:1]
        ax.plot(angles, values, "o-", linewidth=1.5, label=clone_name,
                color=clone_colors[clone_name], markersize=4)
        ax.fill(angles, values, alpha=0.1, color=clone_colors[clone_name])

    ax.set_xticks(angles[:-1])
    ax.set_xticklabels([c.replace("_", " ").title() for c in radar_cols], fontsize=9)
    ax.set_ylim(0, 1.1)
    ax.set_title(f"Clone Radar — Normalized Medians{title_suffix}", fontsize=12, pad=20)
    ax.legend(loc="upper left", bbox_to_anchor=(1.15, 1.1), fontsize=9)

    # Explanatory annotation
    fig.text(0.5, -0.02,
             "Each axis shows MinMax-normalized clone median (0-1). "
             "Further from center = better performance.",
             ha="center", fontsize=9, style="italic", color="gray")
    save_figure(fig, os.path.join(output_dir, "03b_clone_radar.png"))


# ============================================================
# Plot 04a/04b/04c: Feeding strategy
# ============================================================

def plot_feeding_strategy(df, kpi_df, output_dir):
    """Cumulative feeds (04a), process param KDE (04b), feed vs titer scatter (04c)."""
    available_feeds = [c for c in FEED_COLS if c in df.columns]
    clone_names = df[CLONE_COL].unique()
    clone_colors = _get_clone_colors(clone_names)
    clone_ls = _get_clone_linestyles(clone_names)

    # 04a: Cumulative feed curves
    if available_feeds:
        n_feeds = len(available_feeds)
        fig, axes = plt.subplots(1, n_feeds, figsize=(5 * n_feeds, 4))
        if n_feeds == 1:
            axes = [axes]
        for ax, fcol in zip(axes, available_feeds):
            for exp_id, grp in df.groupby(EXP_ID_COL):
                clone = grp[CLONE_COL].iloc[0]
                cumfeed = grp[fcol].fillna(0).cumsum()
                ax.plot(grp[TIME_COL].values, cumfeed.values,
                        color=clone_colors[clone], alpha=0.3, linewidth=1.0,
                        linestyle=clone_ls[clone])
            ax.set_xlabel("Time (h)")
            ax.set_ylabel(FEED_LABELS.get(fcol, fcol))
            ax.set_title(f"Cumulative {fcol}")

        handles = [mpatches.Patch(color=clone_colors[n], label=n) for n in sorted(clone_names)]
        ncol = _adaptive_ncol(len(handles))
        fig.legend(handles=handles, loc="lower center", fontsize=8, ncol=ncol,
                   bbox_to_anchor=(0.5, -0.02))
        fig.text(0.5, -0.06,
                 "Cumulative feed volume over time. Diverging trajectories indicate different feeding strategies across runs.",
                 ha="center", fontsize=9, style="italic", color="gray")
        fig.tight_layout(rect=[0, 0.10, 1, 1])
        save_figure(fig, os.path.join(output_dir, "04a_cumulative_feeds.png"))

    # 04b: Process parameter KDE — all CONTROL_COLS, no clone grouping
    available_controls = [c for c in CONTROL_COLS if c in df.columns]
    if available_controls:
        n_ctrl = len(available_controls)
        fig, axes = plt.subplots(1, n_ctrl, figsize=(5 * n_ctrl, 4))
        if n_ctrl == 1:
            axes = [axes]
        for ax, ccol in zip(axes, available_controls):
            col_data = df[ccol].dropna()
            if len(col_data) > 0:
                sns.kdeplot(data=col_data, ax=ax, fill=True, alpha=0.3, color="steelblue")
            ax.set_title(f"{ccol} Distribution")
            ax.set_xlabel(ccol)
        fig.tight_layout()
        save_figure(fig, os.path.join(output_dir, "04b_process_params.png"))

    # 04c: Cumulative feed vs titer scatter
    if ("cum_feed_glc" in kpi_df.columns and "final_titer" in kpi_df.columns
            and CLONE_COL in kpi_df.columns):
        plot_df = kpi_df[["cum_feed_glc", "final_titer", CLONE_COL]].dropna()
        if len(plot_df) >= 3:
            fig, ax = plt.subplots(figsize=(7, 5))
            colors = _get_clone_colors(plot_df[CLONE_COL].unique())
            sns.scatterplot(data=plot_df, x="cum_feed_glc", y="final_titer",
                            hue=CLONE_COL, palette=colors, s=50, alpha=0.7, ax=ax)
            # Linear regression line + R²
            x = plot_df["cum_feed_glc"].values
            y = plot_df["final_titer"].values
            mask_valid = np.isfinite(x) & np.isfinite(y)
            if mask_valid.sum() >= 2:
                coeffs = np.polyfit(x[mask_valid], y[mask_valid], 1)
                x_line = np.linspace(x[mask_valid].min(), x[mask_valid].max(), 100)
                ax.plot(x_line, np.polyval(coeffs, x_line), "k--", alpha=0.5, linewidth=1)
                ss_res = np.sum((y[mask_valid] - np.polyval(coeffs, x[mask_valid])) ** 2)
                ss_tot = np.sum((y[mask_valid] - y[mask_valid].mean()) ** 2)
                r2 = 1 - ss_res / ss_tot if ss_tot > 0 else 0
                ax.annotate(f"R² = {r2:.3f}", xy=(0.05, 0.95), xycoords="axes fraction",
                            fontsize=10, ha="left", va="top",
                            bbox=dict(boxstyle="round,pad=0.3", fc="white", alpha=0.8))
            ax.set_xlabel("Cumulative Glucose Feed")
            ax.set_ylabel("Final Titer (mg/L)")
            ax.set_title("Cumulative Feed vs Final Titer")
            # Legend outside right
            ax.legend(bbox_to_anchor=(1.05, 1), loc="upper left", fontsize=8)
            fig.text(0.5, -0.02,
                     "Each dot is one run. Trend line shows linear fit; R\u00b2 near 0 suggests feed amount alone does not predict titer.",
                     ha="center", fontsize=9, style="italic", color="gray")
            fig.tight_layout()
            save_figure(fig, os.path.join(output_dir, "04c_feed_vs_titer.png"))


# ============================================================
# Plot 05: PCA + KMeans clustering
# ============================================================

def plot_pca_clustering(df, n_clusters=5, n_timepoints=10, output_dir="eda_results"):
    """PCA on batch-unfolded state trajectories with KMeans clustering."""
    available_states = [c for c in STATE_COLS if c in df.columns]
    if len(available_states) < 2:
        logger.warning("Not enough state columns for PCA; skipping.")
        return

    unique_ids = df[EXP_ID_COL].unique()
    clone_map = {}  # exp_id -> clone_name
    unfolded = []
    valid_ids = []

    for uid in unique_ids:
        grp = df[df[EXP_ID_COL] == uid].sort_values(TIME_COL)
        clone_map[uid] = grp[CLONE_COL].iloc[0]

        state_vals = grp[available_states].copy()
        # Interpolate NaN within each experiment
        state_vals = state_vals.interpolate(method="linear", limit_direction="both")
        state_vals = state_vals.fillna(0)
        arr = state_vals.values

        # Resample to fixed length
        seq_len = len(arr)
        if seq_len >= n_timepoints:
            indices = np.linspace(0, seq_len - 1, n_timepoints, dtype=int)
            resampled = arr[indices]
        else:
            padding = np.tile(arr[-1:], (n_timepoints - seq_len, 1))
            resampled = np.vstack([arr, padding])

        features = resampled.flatten()
        if np.isfinite(features).all():
            unfolded.append(features)
            valid_ids.append(uid)
        else:
            logger.warning("Skipping experiment %s: contains NaN/Inf after interpolation", uid)

    if len(unfolded) < n_clusters:
        logger.warning("Only %d valid experiments (< %d clusters); skipping PCA.",
                       len(unfolded), n_clusters)
        return

    X = np.array(unfolded)
    X_scaled = StandardScaler().fit_transform(X)

    pca = PCA(n_components=2)
    X_pca = pca.fit_transform(X_scaled)

    actual_k = min(n_clusters, len(X_pca))
    labels = KMeans(n_clusters=actual_k, random_state=42, n_init=10).fit_predict(X_pca)

    # Clone markers — extended list with cycling
    clone_names = sorted(set(clone_map[uid] for uid in valid_ids))
    clone_marker = {c: MARKER_LIST[i % len(MARKER_LIST)] for i, c in enumerate(clone_names)}
    clone_colors = _get_clone_colors(clone_names)

    fig, ax = plt.subplots(figsize=(8, 6))
    cmap = plt.get_cmap("Set2", actual_k)

    for i, uid in enumerate(valid_ids):
        clone = clone_map[uid]
        ax.scatter(X_pca[i, 0], X_pca[i, 1],
                   c=[cmap(labels[i])], marker=clone_marker[clone],
                   s=60, alpha=0.7, edgecolors="k", linewidths=0.3)

    # Cluster legend — upper left on axes
    cluster_handles = [mpatches.Patch(color=cmap(k), label=f"Cluster {k}")
                       for k in range(actual_k)]
    leg1 = ax.legend(handles=cluster_handles, loc="upper left", title="Cluster", fontsize=8)
    ax.add_artist(leg1)

    # Clone legend — outside right
    clone_handles = [plt.Line2D([0], [0], marker=clone_marker[c], color=clone_colors[c],
                                linestyle="None", markersize=7, label=c)
                     for c in clone_names]
    ax.legend(handles=clone_handles, loc="upper left", bbox_to_anchor=(1.02, 1),
              title="Clone", fontsize=8, ncol=1)

    ev = pca.explained_variance_ratio_
    ax.set_xlabel(f"PC1 ({ev[0]:.1%} variance)")
    ax.set_ylabel(f"PC2 ({ev[1]:.1%} variance)")
    ax.set_title(f"PCA + KMeans (k={actual_k}) on Batch-Unfolded States")
    fig.text(0.5, -0.02,
             "Batch-unfolded state trajectories projected to 2D. Color = KMeans cluster, marker shape = clone identity.",
             ha="center", fontsize=9, style="italic", color="gray")
    fig.tight_layout()
    save_figure(fig, os.path.join(output_dir, "05_pca_clustering.png"))


