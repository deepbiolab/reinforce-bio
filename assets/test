def make_interp_fn(times, values, method="linear"):
    """
    Build a closure that interpolates batched time-series data at arbitrary t.

    Args:
        times:  [B, T] monotonically increasing time grids.
        values: [B, T, C] corresponding values.
        method: "linear" for linear interpolation, "previous" for zero-order hold.

    Returns:
        fn(t) -> [B, C] where t is a scalar tensor (from ODE solver).
    """
    # Pre-extract shapes; ensure contiguous layout for searchsorted performance
    B, T, C = values.shape
    times = times.contiguous()
    values = values.contiguous()

    def fn(t):
        # t is a scalar tensor from odeint; expand to [B]
        t_expanded = t.expand(B)  # [B]

        # Clamp t to valid range per batch element
        t_min = times[:, 0]      # [B]
        t_max = times[:, -1]     # [B]
        t_clamped = torch.clamp(t_expanded, min=t_min, max=t_max)

        # Vectorized binary search: find right boundary index for each batch
        # searchsorted returns index where t would be inserted to keep sorted order
        idx_right = torch.searchsorted(times, t_clamped.unsqueeze(-1))  # [B, 1]
        idx_right = idx_right.squeeze(-1)  # [B]

        # Clamp indices to valid range [1, T-1] so idx_left = idx_right - 1 >= 0
        idx_right = torch.clamp(idx_right, min=1, max=T - 1)
        idx_left = idx_right - 1

        # Gather time boundaries: t_low, t_high per batch element
        t_low = times[torch.arange(B, device=times.device), idx_left]    # [B]
        t_high = times[torch.arange(B, device=times.device), idx_right]  # [B]

        # Gather value boundaries: [B, C]
        batch_idx = torch.arange(B, device=values.device)
        v_low = values[batch_idx, idx_left]    # [B, C]
        v_high = values[batch_idx, idx_right]  # [B, C]

        if method == "previous":
            return v_low

        # Linear interpolation: alpha = (t - t_low) / (t_high - t_low)
        dt = t_high - t_low                              # [B]
        dt_safe = torch.clamp(dt, min=1e-8)
        alpha = ((t_clamped - t_low) / dt_safe).unsqueeze(-1)  # [B, 1]
        return v_low + alpha * (v_high - v_low)           # [B, C]

    return fn


def make_volume_fn(times, vol_rates, initial_vols):
    """
    Build a closure that computes volume at arbitrary time t via pre-computed
    cumulative volume profile.

    Args:
        times:        [B, T] time grids.
        vol_rates:    [B, T] volumetric addition rates (L/h).
        initial_vols: [B] starting volumes.

    Returns:
        fn(t) -> [B] volume at time t.
    """
    B, T = times.shape

    # Compute dt between consecutive timepoints: [B, T]
    dt = torch.zeros_like(times)
    dt[:, 1:] = times[:, 1:] - times[:, :-1]

    # Cumulative added volume at each timepoint: [B, T]
    incremental = vol_rates * dt                       # [B, T]
    cum_vol = torch.cumsum(incremental, dim=1)         # [B, T]
    total_vol = initial_vols.unsqueeze(-1) + cum_vol   # [B, T]

    # Reuse make_interp_fn for 1-channel interpolation
    interp = make_interp_fn(times, total_vol.unsqueeze(-1), method="linear")

    def fn(t):
        return interp(t).squeeze(-1)  # [B]

    return fn


def make_vol_rate_fn(times, vol_rates):
    """
    Build a closure that interpolates volumetric addition rate at arbitrary t.

    Args:
        times:     [B, T] time grids.
        vol_rates: [B, T] volumetric addition rates (L/h).

    Returns:
        fn(t) -> [B] vol_rate at time t (zero-order hold).
    """
    # Use previous-value (ZOH) interpolation — rate is piecewise constant
    interp = make_interp_fn(
        times, vol_rates.unsqueeze(-1), method="previous",
    )

    def fn(t):
        return interp(t).squeeze(-1)  # [B]

    return fn


class KineticsNet(nn.Module):
    """
    MLP that predicts per-state kinetic rates from normalized process state,
    controls, statics, and a learned clone embedding.

    Architecture:
        [n_states + n_controls + n_statics + emb_dim] → 64 → Tanh → 64 → Tanh → n_states

    The last layer is initialized with very small weights so that initial
    predicted rates are near zero, stabilizing ODE integration at startup.
    """

    def __init__(self, n_states, n_controls, n_statics, n_clones,
                 emb_dim=8, hidden_dim=64):
        super().__init__()
        self.clone_emb = nn.Embedding(n_clones, emb_dim)
        input_dim = n_states + n_controls + n_statics + emb_dim

        self.net = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.Tanh(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.Tanh(),
            nn.Linear(hidden_dim, n_states),
        )

        # --- Weight initialization ---
        # Embedding: small normal for smooth initial embeddings
        nn.init.normal_(self.clone_emb.weight, mean=0.0, std=0.1)

        # Hidden layers: Xavier uniform for stable gradient flow with Tanh
        for layer in [self.net[0], self.net[2]]:
            if isinstance(layer, nn.Linear):
                nn.init.xavier_uniform_(layer.weight)
                nn.init.zeros_(layer.bias)

        # Output layer: near-zero to start with tiny rates → stable ODE
        output_layer = self.net[4]
        if isinstance(output_layer, nn.Linear):
            nn.init.normal_(output_layer.weight, mean=0.0, std=1e-4)
            nn.init.zeros_(output_layer.bias)

    def forward(self, x_continuous, clone_idx):
        """
        Args:
            x_continuous: [B, n_states + n_controls + n_statics] (pre-normalized).
            clone_idx:    [B] LongTensor of clone indices.

        Returns:
            rates: [B, n_states] predicted kinetic rates.
        """
        emb = self.clone_emb(clone_idx)                  # [B, emb_dim]
        return self.net(torch.cat([x_continuous, emb], dim=-1))


class HybridODE(nn.Module):
    """
    Neural ODE right-hand side: dX/dt = NN_rates × biomass + feeds − dilution.

    Composes a KineticsNet with process interpolation closures to compute
    the state derivative at any time t during ODE integration.

    Equation per state i:
        If empirical:   dX_i/dt = rate_i  (direct NN output)
        If biomass:     dX_i/dt = rate_i × VCD
        Otherwise:      dX_i/dt = sign_i × rate_i × VCD
                                + Σ(feed_j × factor_j / V)
                                − X_i × (vol_rate / V)  [dilution, ODE states only]
    """
    state_mean: torch.Tensor
    state_std: torch.Tensor
    control_mean: torch.Tensor
    control_std: torch.Tensor
    static_mean: torch.Tensor
    static_std: torch.Tensor
    state_signs: torch.Tensor
    dilution_mask: torch.Tensor

    def __init__(self, net, ctrl_fn, feed_fn, vol_fn, vol_rate_fn,
                 stats, clone_idx, statics, cfg):
        super().__init__()
        self.net = net
        self.ctrl_fn = ctrl_fn            # closure(t) -> [B, n_controls]
        self.feed_fn = feed_fn            # closure(t) -> [B, n_feeds]
        self.vol_fn = vol_fn              # closure(t) -> [B]
        self.vol_rate_fn = vol_rate_fn    # closure(t) -> [B]
        self.clone_idx = clone_idx        # [B] LongTensor
        self.statics = statics            # [B, n_statics]
        self.cfg = cfg

        # Register normalization stats as buffers (move with .to(device))
        self.register_buffer("state_mean", stats["state_mean"])
        self.register_buffer("state_std", stats["state_std"])
        self.register_buffer("control_mean", stats["control_mean"])
        self.register_buffer("control_std", stats["control_std"])
        self.register_buffer("static_mean", stats["static_mean"])
        self.register_buffer("static_std", stats["static_std"])

        current_device = stats["state_mean"].device

        # State sign tensor: +1 for produced, -1 for consumed
        state_cols = cfg["state_cols"]
        signs = torch.tensor(
            [cfg["state_signs"][c] for c in state_cols], 
            dtype=torch.float32,
            device=current_device
        )
        self.register_buffer("state_signs", signs)

        # Dilution mask: 1.0 for ODE states subject to dilution, 0.0 for empirical
        empirical_set = set(cfg["empirical_states"])
        dilution_mask = torch.tensor(
            [0.0 if c in empirical_set else 1.0 for c in state_cols],
            dtype=torch.float32,
            device=current_device
        )
        self.register_buffer("dilution_mask", dilution_mask)

        # Feed contribution mapping: state_idx → [(feed_idx, concentration_factor)]
        feed_cols = cfg["feed_cols"]
        self.feed_contribs = {}
        for state_name, entries in cfg["feed_to_state"].items():
            si = state_cols.index(state_name)
            self.feed_contribs[si] = [
                (feed_cols.index(fc), factor) for fc, factor in entries
            ]

        # Cache frequently used indices
        self.biomass_idx = state_cols.index(cfg["biomass_col"])
        self.empirical_indices = frozenset(
            state_cols.index(c) for c in cfg["empirical_states"]
        )

    def forward(self, t, y):
        """
        ODE right-hand side called by torchdiffeq.odeint.

        Args:
            t: scalar tensor — current integration time.
            y: [B, n_states] current state vector.

        Returns:
            dxdt: [B, n_states] state derivatives.
        """
        B, n_states = y.shape

        # 1. Interpolate process inputs at time t
        controls = self.ctrl_fn(t)      # [B, n_controls]
        feeds = self.feed_fn(t)         # [B, n_feeds]
        volume = self.vol_fn(t)         # [B]
        vol_rate = self.vol_rate_fn(t)  # [B]

        # 2. Normalize inputs for the NN
        norm_y = (y - self.state_mean) / self.state_std
        norm_ctrl = (controls - self.control_mean) / self.control_std
        norm_static = (self.statics - self.static_mean) / self.static_std

        # 3. Predict kinetic rates
        x_continuous = torch.cat([norm_y, norm_ctrl, norm_static], dim=-1)
        rates = self.net(x_continuous, self.clone_idx)  # [B, n_states]

        # 4. Assemble dX/dt: rate × biomass (with sign conventions)
        vcd = torch.relu(y[:, self.biomass_idx])  # [B], non-negative viable cell density
        dxdt = torch.zeros_like(y)

        for i in range(n_states):
            if i in self.empirical_indices:
                # Empirical states: NN directly predicts the derivative
                dxdt[:, i] = rates[:, i]
            elif i == self.biomass_idx:
                # Biomass: rate × current biomass (logistic-like growth)
                dxdt[:, i] = rates[:, i] * vcd
            else:
                # Metabolites: sign × rate × biomass
                dxdt[:, i] = self.state_signs[i] * rates[:, i] * vcd

        # 5. Feed contributions: feed_rate × concentration_factor / volume
        vol_safe = torch.clamp(volume, min=1e-6)  # [B]
        for si, entries in self.feed_contribs.items():
            for fi, factor in entries:
                dxdt[:, si] = dxdt[:, si] + feeds[:, fi] * factor / vol_safe

        # 6. Dilution: −X × (vol_rate / volume), only for non-empirical states
        dilution = vol_rate / vol_safe                              # [B]
        dxdt = dxdt - y * dilution.unsqueeze(-1) * self.dilution_mask.unsqueeze(0)

        return dxdt


def create_model(n_clones, cfg):
    """
    Factory: create a KineticsNet with dimensions derived from cfg.

    Args:
        n_clones: number of unique clones (embedding vocabulary size).
        cfg:      global configuration dict.

    Returns:
        KineticsNet instance (not yet moved to device).
    """
    return KineticsNet(
        n_states=len(cfg["state_cols"]),
        n_controls=len(cfg["control_cols"]),
        n_statics=len(cfg["static_cols"]),
        n_clones=n_clones,
        emb_dim=cfg["clone_emb_dim"],
        hidden_dim=cfg["hidden_dim"],
    )


# ============================================================
# S3: ODE Integration
# ============================================================


def solve_batch(net, batch, stats, cfg):
    """
    Free-run ODE integration for a batch of experiments.

    Args:
        net: KineticsNet model.
        batch: BatchData namedtuple (padded).
        stats: normalisation stats dict (tensors on any device).
        cfg: configuration dict.

    Returns:
        predictions: [B, T, n_states] predicted trajectories.
        t_eval: [T] evaluation time points.
    """
    device = batch.times.device

    # Determine real time range using pad_masks
    # pad_masks: [B, T], 1 = real measurement, 0 = padding
    max_T = batch.times.shape[1]
    real_mask = batch.pad_masks > 0.5  # [B, T]
    # Replace padded positions with +inf / -inf so they don't affect min/max
    masked_times = batch.times.clone()
    masked_times[~real_mask] = float("inf")
    t_start = masked_times.min()
    masked_times[~real_mask] = float("-inf")
    t_end = masked_times.max()

    t_eval = torch.linspace(
        t_start.item(), t_end.item(), max_T, device=device
    )

    # Build interpolation closures
    ctrl_fn = make_interp_fn(batch.times, batch.controls, method="linear")
    feed_fn = make_interp_fn(batch.times, batch.feed_rates, method="previous")
    vol_fn = make_volume_fn(batch.times, batch.vol_rates, batch.initial_vols)
    vol_rate_fn = make_vol_rate_fn(batch.times, batch.vol_rates)

    # Move stats tensors to the correct device
    stats_dev = {k: v.to(device) for k, v in stats.items()}

    # Build ODE right-hand side
    ode_func = HybridODE(
        net=net,
        ctrl_fn=ctrl_fn,
        feed_fn=feed_fn,
        vol_fn=vol_fn,
        vol_rate_fn=vol_rate_fn,
        stats=stats_dev,
        clone_idx=batch.clone_indices,
        statics=batch.statics,
        cfg=cfg,
    )

    # Initial conditions: [B, n_states]
    y0 = batch.initial_states

    # Solve ODE — solution shape: [T, B, n_states]
    solution = odeint(
        ode_func,
        y0,
        t_eval,
        method=cfg["ode_method"],
        rtol=cfg["ode_rtol"],
        atol=cfg["ode_atol"],
    )

    # Transpose to [B, T, n_states]
    predictions = solution.permute(1, 0, 2)

    # NaN guard: warn and replace with zeros
    if torch.isnan(predictions).any():
        logger.warning("NaN detected in ODE solution — clamping to 0.")
        predictions = torch.nan_to_num(predictions, nan=0.0)

    return predictions, t_eval


def interp_to_targets(preds, pred_times, target_times, pad_masks):
    """
    Vectorised linear interpolation of ODE predictions to measurement times.

    Args:
        preds: [B, T_pred, n_states] ODE solution on a uniform grid.
        pred_times: [T_pred] ODE evaluation time points (sorted).
        target_times: [B, T_target] per-experiment measurement times.
        pad_masks: [B, T_target] 1 = real, 0 = padding.

    Returns:
        interp_preds: [B, T_target, n_states] interpolated predictions.
    """
    B, T_target = target_times.shape
    n_states = preds.shape[2]
    device = preds.device

    # Flatten target times for a single searchsorted call
    flat_t = target_times.reshape(-1)  # [B * T_target]

    # Find right-side insertion indices, clamp to valid range [1, T_pred-1]
    idx_hi = torch.searchsorted(pred_times, flat_t).clamp(1, len(pred_times) - 1)
    idx_lo = idx_hi - 1

    t_lo = pred_times[idx_lo]  # [B*T_target]
    t_hi = pred_times[idx_hi]  # [B*T_target]
    alpha = ((flat_t - t_lo) / (t_hi - t_lo + 1e-8)).clamp(0.0, 1.0)  # [B*T_target]

    # Reshape indices for gather: [B, T_target]
    idx_lo = idx_lo.view(B, T_target)
    idx_hi = idx_hi.view(B, T_target)
    alpha = alpha.view(B, T_target, 1)  # [B, T_target, 1] for broadcasting

    # Gather predictions at lo/hi indices: expand to [B, T_target, n_states]
    idx_lo_exp = idx_lo.unsqueeze(-1).expand(-1, -1, n_states)
    idx_hi_exp = idx_hi.unsqueeze(-1).expand(-1, -1, n_states)

    preds_lo = torch.gather(preds, 1, idx_lo_exp)  # [B, T_target, n_states]
    preds_hi = torch.gather(preds, 1, idx_hi_exp)  # [B, T_target, n_states]

    interp_preds = (1.0 - alpha) * preds_lo + alpha * preds_hi

    # Zero out padding positions
    mask = (pad_masks > 0.5).unsqueeze(-1)  # [B, T_target, 1]
    interp_preds = interp_preds * mask

    return interp_preds


# -- Stepwise helpers --------------------------------------------------------


def _find_ground_truth(batch, target_time, tolerance):
    """
    Find observations closest to *target_time* within *tolerance* (hours).

    Returns:
        y_true: [B, n_states] ground-truth state values (0 where unavailable).
        mask: [B, n_states] observation mask (1 = observed, 0 = missing).
        has_reset: bool — True if at least one experiment had a valid observation.
    """
    B, T, n_states = batch.states.shape
    device = batch.states.device
    y_true = torch.zeros(B, n_states, device=device)
    mask = torch.zeros(B, n_states, device=device)
    has_reset = False

    for b in range(B):
        valid = batch.pad_masks[b] > 0.5
        valid_times = batch.times[b, valid]
        if len(valid_times) == 0:
            continue
        diffs = torch.abs(valid_times - target_time)
        min_diff, min_idx = diffs.min(dim=0)
        if min_diff.item() <= tolerance:
            orig_idx = valid.nonzero(as_tuple=False)[min_idx].item()
            y_true[b] = batch.states[b, orig_idx]
            mask[b] = batch.obs_masks[b, orig_idx]
            has_reset = True

    return y_true, mask, has_reset


def solve_batch_stepwise(net, batch, stats, cfg):
    """
    Stepwise ODE integration with periodic state resets from observations.

    Splits the time horizon into segments of ``cfg["step_size_hours"]``.
    At each segment boundary the predicted state is replaced by ground-truth
    observations (where available within ``cfg["reset_tolerance"]`` hours).

    Args:
        net: KineticsNet model.
        batch: BatchData namedtuple.
        stats: normalisation stats dict.
        cfg: configuration dict.

    Returns:
        predictions: [B, T_total, n_states] concatenated trajectory.
        pred_times: [T_total] time points.
        reset_times: list of float times where resets occurred.
    """
    device = batch.times.device
    step_size = cfg["step_size_hours"]
    tolerance = cfg["reset_tolerance"]

    # Determine real time range
    real_mask = batch.pad_masks > 0.5
    masked_times = batch.times.clone()
    masked_times[~real_mask] = float("inf")
    t_start = masked_times.min().item()
    masked_times[~real_mask] = float("-inf")
    t_end = masked_times.max().item()

    # Segment boundaries
    boundaries = []
    t = t_start
    while t < t_end - 1e-6:
        boundaries.append(t)
        t += step_size
    boundaries.append(t_end)

    # Shared interpolation closures (cover the full time span)
    ctrl_fn = make_interp_fn(batch.times, batch.controls, method="linear")
    feed_fn = make_interp_fn(batch.times, batch.feed_rates, method="previous")
    vol_fn = make_volume_fn(batch.times, batch.vol_rates, batch.initial_vols)
    vol_rate_fn = make_vol_rate_fn(batch.times, batch.vol_rates)
    stats_dev = {k: v.to(device) for k, v in stats.items()}

    # Per-segment ODE solve
    y_current = batch.initial_states.clone()  # [B, n_states]
    all_preds = []  # list of [B, T_seg, n_states]
    all_times = []  # list of [T_seg]
    reset_times = []
    n_pts_per_seg = max(batch.times.shape[1] // max(len(boundaries) - 1, 1), 4)

    for i in range(len(boundaries) - 1):
        seg_start = boundaries[i]
        seg_end = boundaries[i + 1]
        t_seg = torch.linspace(seg_start, seg_end, n_pts_per_seg, device=device)

        ode_func = HybridODE(
            net=net,
            ctrl_fn=ctrl_fn,
            feed_fn=feed_fn,
            vol_fn=vol_fn,
            vol_rate_fn=vol_rate_fn,
            stats=stats_dev,
            clone_idx=batch.clone_indices,
            statics=batch.statics,
            cfg=cfg,
        )

        solution = odeint(
            ode_func,
            y_current,
            t_seg,
            method=cfg["ode_method"],
            rtol=cfg["ode_rtol"],
            atol=cfg["ode_atol"],
        )  # [T_seg, B, n_states]

        seg_preds = solution.permute(1, 0, 2)  # [B, T_seg, n_states]

        # NaN guard
        if torch.isnan(seg_preds).any():
            logger.warning(
                "NaN in stepwise segment %d (%.1f–%.1f h) — clamping.",
                i, seg_start, seg_end,
            )
            seg_preds = torch.nan_to_num(seg_preds, nan=0.0)

        # Avoid duplicating boundary points between consecutive segments
        if i > 0:
            seg_preds = seg_preds[:, 1:]
            t_seg = t_seg[1:]

        all_preds.append(seg_preds)
        all_times.append(t_seg)

        # State reset at segment boundary
        y_pred_end = seg_preds[:, -1]  # [B, n_states]
        y_true, obs_mask, has_reset = _find_ground_truth(
            batch, seg_end, tolerance
        )
        if has_reset:
            y_current = obs_mask * y_true + (1.0 - obs_mask) * y_pred_end
            reset_times.append(seg_end)
        else:
            y_current = y_pred_end

    predictions = torch.cat(all_preds, dim=1)  # [B, T_total, n_states]
    pred_times = torch.cat(all_times, dim=0)  # [T_total]
    return predictions, pred_times, reset_times


# -- Ensemble wrappers -------------------------------------------------------


def solve_ensemble(models, batch, stats, cfg):
    """
    Free-run ODE with each ensemble member; return mean, std, and all.

    Returns:
        mean_preds: [B, T, n_states]
        std_preds: [B, T, n_states]
        all_preds: [N, B, T, n_states]
        t_eval: [T]
    """
    all_preds = []
    t_eval = None
    for net in models:
        net.eval()
        with torch.no_grad():
            preds, t_eval = solve_batch(net, batch, stats, cfg)
            all_preds.append(preds)
    all_preds = torch.stack(all_preds, dim=0)  # [N, B, T, n_states]
    mean_preds = all_preds.mean(dim=0)
    std_preds = all_preds.std(dim=0)
    return mean_preds, std_preds, all_preds, t_eval


def solve_ensemble_stepwise(models, batch, stats, cfg):
    """
    Stepwise ODE with each ensemble member; return mean, std, and all.

    Returns:
        mean_preds: [B, T_total, n_states]
        std_preds: [B, T_total, n_states]
        all_preds: [N, B, T_total, n_states]
        pred_times: [T_total]
        reset_times: list of float reset boundary times.
    """
    all_preds = []
    pred_times = None
    reset_times = None
    for net in models:
        net.eval()
        with torch.no_grad():
            preds, pred_times, reset_times = solve_batch_stepwise(
                net, batch, stats, cfg
            )
            all_preds.append(preds)
    all_preds = torch.stack(all_preds, dim=0)  # [N, B, T_total, n_states]
    mean_preds = all_preds.mean(dim=0)
    std_preds = all_preds.std(dim=0)
    return mean_preds, std_preds, all_preds, pred_times, reset_times


# ============================================================
# S4: Training
# ============================================================


def masked_nrmse(
    pred: torch.Tensor,
    target: torch.Tensor,
    obs_mask: torch.Tensor,
    state_std: torch.Tensor,
) -> torch.Tensor:
    """Compute masked normalized RMSE per state variable.

    Args:
        pred: [B, T, n_states] predicted values.
        target: [B, T, n_states] observed values.
        obs_mask: [B, T, n_states] — 1 where observed, 0 otherwise.
        state_std: [n_states] — normalization denominator.

    Returns:
        nrmse: [n_states] — per-variable normalized RMSE.
    """
    diff = (pred - target) * obs_mask
    n_obs = obs_mask.sum(dim=(0, 1)).clamp(min=1.0)
    mse = (diff ** 2).sum(dim=(0, 1)) / n_obs
    rmse = torch.sqrt(mse)
    return rmse / state_std.clamp(min=1e-6)


def _evaluate_nrmse(
    net: nn.Module,
    data: dict,
    exp_ids: list,
    stats: dict,
    cfg: dict,
    device: torch.device,
) -> float:
    """Compute average NRMSE on given experiment IDs (no grad)."""
    if not exp_ids:
        return float("inf")

    net.eval()
    state_std = stats["state_std"].to(device)
    all_nrmse: list[float] = []
    batch_size = cfg["batch_size"]

    with torch.no_grad():
        for i in range(0, len(exp_ids), batch_size):
            batch_ids = exp_ids[i : i + batch_size]
            batch = make_batch(batch_ids, data, device)
            try:
                preds, t_eval = solve_batch(net, batch, stats, cfg)
                if torch.isnan(preds).any():
                    continue
                interp = interp_to_targets(preds, t_eval, batch.times, batch.pad_masks)
                nrmse = masked_nrmse(interp, batch.states, batch.obs_masks, state_std)
                all_nrmse.append(nrmse.mean().item())
            except Exception as e:
                logger.debug("Eval batch skipped: %s", e)
                continue

    return float(np.mean(all_nrmse)) if all_nrmse else float("inf")


def train_one_model(
    net: nn.Module,
    data: dict,
    train_ids: list,
    val_ids: list,
    stats: dict,
    cfg: dict,
    device: torch.device,
    label: str = "",
) -> tuple:
    """Train a single KineticsNet with early stopping.

    Returns:
        net: trained model (loaded from best checkpoint in memory).
        history: {"train_loss": [...], "val_nrmse": [...]}.
    """
    net = net.to(device)
    optimizer = torch.optim.Adam(net.parameters(), lr=cfg["lr"], weight_decay=1e-4)

    warmup_epochs = cfg['warmup_epochs']
    warmup_scheduler = torch.optim.lr_scheduler.LinearLR(
        optimizer, 
        start_factor=0.01,  # 从设定学习率的 1% 开始 (即 2e-5)
        total_iters=warmup_epochs
    )

    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
            optimizer,
            mode='min',
            factor=0.5,       # 每次衰减为原来的一半 (比如 2e-3 -> 1e-3)
            patience=8,       # 容忍 8 个 epoch 不下降就开始衰减 LR
            min_lr=1e-5       # 学习率兜底下限
        )

    best_val = float("inf")
    best_state: dict | None = None
    patience_counter = 0
    history: dict[str, list[float]] = {"train_loss": [], "val_nrmse": []}

    state_std = stats["state_std"].to(device)

    for epoch in range(cfg["epochs"]):
        net.train()
        epoch_loss = 0.0
        n_batches = 0

        # Shuffle training IDs
        perm = np.random.permutation(train_ids)
        batch_size = cfg["batch_size"]

        for i in range(0, len(perm), batch_size):
            batch_ids = list(perm[i : i + batch_size])
            batch = make_batch(batch_ids, data, device)

            optimizer.zero_grad()
            try:
                preds, t_eval = solve_batch(net, batch, stats, cfg)
                if torch.isnan(preds).any():
                    logger.warning(
                        "%s Epoch %d batch %d: NaN in predictions, skipping",
                        label, epoch + 1, i,
                    )
                    continue

                interp = interp_to_targets(preds, t_eval, batch.times, batch.pad_masks)
                nrmse_vec = masked_nrmse(interp, batch.states, batch.obs_masks, state_std)
                loss = nrmse_vec.mean()

                if torch.isnan(loss):
                    continue

                loss.backward()
                torch.nn.utils.clip_grad_norm_(net.parameters(), cfg["grad_clip"])
                optimizer.step()

                epoch_loss += loss.item()
                n_batches += 1
            except Exception as e:
                logger.warning("%s Epoch %d batch %d: %s", label, epoch + 1, i, e)
                continue

        avg_loss = epoch_loss / max(n_batches, 1)
        history["train_loss"].append(avg_loss)

        # Validation
        net.eval()
        val_nrmse = _evaluate_nrmse(net, data, val_ids, stats, cfg, device)
        history["val_nrmse"].append(val_nrmse)

        if epoch < warmup_epochs:
            warmup_scheduler.step()
        else:
            scheduler.step(val_nrmse)

        current_lr = optimizer.param_groups[0]['lr']

        # Early stopping
        if val_nrmse < best_val:
            best_val = val_nrmse
            best_state = copy.deepcopy(net.state_dict())
            patience_counter = 0
        else:
            patience_counter += 1

        if (epoch + 1) % 10 == 0 or epoch == 0:
            logger.info(
                "%s Epoch %03d | LR: %.2e | Loss: %.5f | Val NRMSE: %.4f | Best: %.4f",
                label, epoch + 1, current_lr, avg_loss, val_nrmse, best_val,
            )
        
        if patience_counter >= cfg["patience"]:
            logger.info("%s Early stopping at epoch %d", label, epoch + 1)
            break

    # Restore best model
    if best_state is not None:
        net.load_state_dict(best_state)

    return net, history


def train_ensemble(
    data: dict,
    train_ids: list,
    val_ids: list,
    stats: dict,
    n_clones: int,
    cfg: dict,
    device: torch.device,
) -> tuple:
    """Train an ensemble of KineticsNet models using K-fold CV.

    Uses product-stratified K-fold: each fold has balanced clone representation.

    Returns:
        models: list of n_ensemble trained KineticsNet.
        histories: list of n_ensemble history dicts.
    """
    n_ensemble = cfg["n_ensemble"]
    all_train = train_ids + val_ids  # combine for K-fold splitting

    # Build stratification labels (clone index for each experiment)
    strat_labels = [data[eid].clone_idx for eid in all_train]

    skf = StratifiedKFold(n_splits=n_ensemble, shuffle=True, random_state=cfg["seed"])

    models: list[nn.Module] = []
    histories: list[dict] = []

    for fold_idx, (fold_train_idx, fold_val_idx) in enumerate(
        skf.split(all_train, strat_labels)
    ):
        logger.info("--- Ensemble model %d/%d ---", fold_idx + 1, n_ensemble)

        # Set different seed per fold for model initialization
        torch.manual_seed(cfg["seed"] + fold_idx * 100)
        np.random.seed(cfg["seed"] + fold_idx * 100)

        fold_train = [all_train[i] for i in fold_train_idx]
        fold_val = [all_train[i] for i in fold_val_idx]

        net = create_model(n_clones, cfg).to(device)
        net, history = train_one_model(
            net, data, fold_train, fold_val, stats, cfg, device,
            label=f"[Model {fold_idx}]",
        )

        models.append(net)
        histories.append(history)

    logger.info("Ensemble training complete: %d models", len(models))
    return models, histories


# ============================================================
# S5: Evaluation & Metrics
# ============================================================


def compute_metrics(
    pred: torch.Tensor,
    target: torch.Tensor,
    obs_mask: torch.Tensor,
    state_std: torch.Tensor,
) -> dict:
    """Compute comprehensive evaluation metrics.

    Args:
        pred: [B, T, n_states] predictions.
        target: [B, T, n_states] ground truth.
        obs_mask: [B, T, n_states] observation mask (1=observed).
        state_std: [n_states] for NRMSE normalization.

    Returns:
        dict with per_var_{nrmse,mape,r2,mae} (numpy) and avg_* (float).
    """
    # NRMSE — reuse existing helper
    nrmse = masked_nrmse(pred, target, obs_mask, state_std)

    # MAPE — skip near-zero targets to avoid division issues
    target_safe = torch.where(
        torch.abs(target) > 1e-6, target, torch.ones_like(target),
    )
    valid_mask = obs_mask * (torch.abs(target) > 1e-6).float()
    abs_pct = torch.abs((pred - target) / target_safe) * valid_mask
    n_valid = valid_mask.sum(dim=(0, 1)).clamp(min=1.0)
    mape = (abs_pct.sum(dim=(0, 1)) / n_valid) * 100.0

    # R² — coefficient of determination
    n_obs = obs_mask.sum(dim=(0, 1)).clamp(min=1.0)
    ss_res = ((pred - target) ** 2 * obs_mask).sum(dim=(0, 1))
    target_mean = (target * obs_mask).sum(dim=(0, 1)) / n_obs
    ss_tot = (
        (target - target_mean.unsqueeze(0).unsqueeze(0)) ** 2 * obs_mask
    ).sum(dim=(0, 1))
    r2 = 1.0 - ss_res / ss_tot.clamp(min=1e-8)

    # MAE — mean absolute error
    abs_err = torch.abs(pred - target) * obs_mask
    mae = abs_err.sum(dim=(0, 1)) / n_obs

    return {
        "per_var_nrmse": nrmse.detach().cpu().numpy(),
        "avg_nrmse": nrmse.mean().item(),
        "per_var_mape": mape.detach().cpu().numpy(),
        "avg_mape": mape.mean().item(),
        "per_var_r2": r2.detach().cpu().numpy(),
        "avg_r2": r2.mean().item(),
        "per_var_mae": mae.detach().cpu().numpy(),
        "avg_mae": mae.mean().item(),
    }


def evaluate_ensemble(models, data, exp_ids, stats, cfg, device):
    """Evaluate ensemble on given experiments using free-run prediction.

    Runs free-run ODE integration for each batch, interpolates to observed
    time points, then computes NRMSE / MAPE / R² / MAE.

    Returns:
        dict with avg_nrmse, avg_mape, avg_r2, avg_mae and per_var versions.
    """
    if not exp_ids:
        return {
            "avg_nrmse": float("inf"),
            "avg_r2": 0.0,
            "avg_mape": float("inf"),
            "avg_mae": float("inf"),
        }

    state_std = stats["state_std"].to(device)

    all_preds: list[torch.Tensor] = []
    all_targets: list[torch.Tensor] = []
    all_masks: list[torch.Tensor] = []

    batch_size = cfg["batch_size"]
    for i in range(0, len(exp_ids), batch_size):
        batch_ids = exp_ids[i : i + batch_size]
        batch = make_batch(batch_ids, data, device)

        # Ensemble mean prediction (free-run)
        mean_pred, _, _, t_eval = solve_ensemble(models, batch, stats, cfg)
        interp = interp_to_targets(mean_pred, t_eval, batch.times, batch.pad_masks)

        all_preds.append(interp)
        all_targets.append(batch.states)
        all_masks.append(batch.obs_masks)

    pred_cat = torch.cat(all_preds, dim=0)
    target_cat = torch.cat(all_targets, dim=0)
    mask_cat = torch.cat(all_masks, dim=0)

    return compute_metrics(pred_cat, target_cat, mask_cat, state_std)


def evaluate_stepwise(models, data, exp_ids, stats, cfg, device):
    """Evaluate ensemble with stepwise prediction (data assimilation).

    Same return format as evaluate_ensemble, plus ``avg_n_resets``.
    """
    if not exp_ids:
        return {
            "avg_nrmse": float("inf"),
            "avg_r2": 0.0,
            "avg_mape": float("inf"),
            "avg_mae": float("inf"),
        }

    state_std = stats["state_std"].to(device)

    all_preds: list[torch.Tensor] = []
    all_targets: list[torch.Tensor] = []
    all_masks: list[torch.Tensor] = []
    all_resets: list[int] = []

    batch_size = cfg["batch_size"]
    for i in range(0, len(exp_ids), batch_size):
        batch_ids = exp_ids[i : i + batch_size]
        batch = make_batch(batch_ids, data, device)

        mean_pred, _, _, pred_times, reset_times = solve_ensemble_stepwise(
            models, batch, stats, cfg,
        )
        interp = interp_to_targets(
            mean_pred, pred_times, batch.times, batch.pad_masks,
        )

        all_preds.append(interp)
        all_targets.append(batch.states)
        all_masks.append(batch.obs_masks)
        all_resets.append(len(reset_times))

    pred_cat = torch.cat(all_preds, dim=0)
    target_cat = torch.cat(all_targets, dim=0)
    mask_cat = torch.cat(all_masks, dim=0)

    metrics = compute_metrics(pred_cat, target_cat, mask_cat, state_std)
    metrics["avg_n_resets"] = float(np.mean(all_resets)) if all_resets else 0.0
    return metrics


